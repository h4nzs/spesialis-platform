[TEMPLATE]
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgres://specialist:specialist@localhost:5432/specialist
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=specialist
DATABASE_USER=specialist
DATABASE_PASSWORD=specialist

# ── Redis (optional in dev — falls back to in-memory) ─────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Authentication ────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-me

# ── Application URLs ─────────────────────────────────────────────────
APP_URL=http://localhost
API_URL=http://localhost/api
PUBLIC_API_URL=http://localhost:3000

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4321,http://localhost:3000,http://localhost

# ── Analytics (Plausible) ─────────────────────────────────────────────
# Plausible server domain (stats.ahlipanggilan.id in production)
# Empty in dev — analytics runs with noop provider
PUBLIC_PLAUSIBLE_DOMAIN=
# Site domain used as Plausible's data-domain attribute
PUBLIC_SITE_DOMAIN=ahlipanggilan.id

# ── ClickHouse (Funnel Analytics) ───────────────────────────────────────
# ClickHouse HTTP endpoint for funnel queries.
# In production, accessible via Docker internal network.
CLICKHOUSE_HOST=http://localhost:8123
# ClickHouse database name (same as Plausible's CLICKHOUSE_DATABASE_URL)
CLICKHOUSE_DATABASE=plausible
# Query timeout in ms (default 30000)
CLICKHOUSE_TIMEOUT=30000

# ── CMS Revalidation ────────────────────────────────────────────────
REVALIDATION_TOKEN=specialist-revalidation-token

# ── Uploads ──────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Email (SMTP / Mailpit) ───────────────────────────────────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ahlipanggilan.id

# ── Resend (production email — falls back to Mailpit via SMTP) ───────
RESEND_API_KEY=
RESEND_FROM=Spesialis <noreply@ahlipanggilan.id>

# ── Object Storage (Cloudflare R2) ───────────────────────────────────
# Jika diisi, upload file akan disimpan ke R2 bukan filesystem lokal
# Dashboard R2 → Buat Bucket → Settings → API / R2.dev domain
# Untuk API Token: Dashboard → My Profile → API Tokens → Create Token (R2:Read+Write)
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY=
R2_SECRET_KEY=
# Public URL — custom domain (misal https://media.ahlipanggilan.id) atau R2.dev subdomain
# Jika kosong, otomatis dibangun dari R2_ENDPOINT + R2_BUCKET
R2_PUBLIC_URL=

# ── WhatsApp Gateway (Fonnte) ────────────────────────────────────────
WHATSAPP_API_URL=https://api.fonnte.com/send
WHATSAPP_API_KEY=

# ── CDN (Cloudflare) — production only ─────────────────────────────
# Generate API token: Cloudflare Dashboard → My Profile → API Tokens
# Permissions needed: Zone > Cache Purge
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
# Public site URL (used to construct full URLs for CDN purge)
SITE_URL=https://ahlipanggilan.id

# E2E: disable rate limiting for tests
RATE_LIMIT_DISABLED=true
# Astro URL for CMS revalidation webhook
ASTRO_URL=http://localhost:4321
