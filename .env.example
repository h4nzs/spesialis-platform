[TEMPLATE]
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgres://specialist:specialist@localhost:5432/specialist
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=specialist
DATABASE_USER=specialist
DATABASE_PASSWORD=specialist

# ── Redis (optional in dev — falls back to in-memory) ─────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Authentication ────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-me

# ── Application URLs ─────────────────────────────────────────────────
APP_URL=http://localhost
API_URL=http://localhost/api
PUBLIC_API_URL=http://localhost:3000

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4321,http://localhost:3000

# ── CMS (Directus) ───────────────────────────────────────────────────
CMS_URL=http://localhost:8055
CMS_TOKEN=specialist-setup-token
REVALIDATION_TOKEN=specialist-revalidation-token
# Directus admin credentials — uncomment for first-time CMS setup:
# These map directly to Directus environment variables.
DIRECTUS_URL=http://localhost:8055
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=admin123
DIRECTUS_SETUP_TOKEN=specialist-setup-token

# ── Uploads ──────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Email (SMTP / Mailpit) ───────────────────────────────────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@spesialis.id

# ── Resend (production email — falls back to Mailpit via SMTP) ───────
RESEND_API_KEY=
RESEND_FROM=Spesialis <noreply@spesialis.id>

# ── Object Storage (Cloudflare R2) ───────────────────────────────────
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY=
R2_SECRET_KEY=

# ── WhatsApp Gateway (Fonnte) ────────────────────────────────────────
WHATSAPP_API_URL=https://api.fonnte.com/send
WHATSAPP_API_KEY=

# ── CDN (Cloudflare) — production only ─────────────────────────────
# Generate API token: Cloudflare Dashboard → My Profile → API Tokens
# Permissions needed: Zone > Cache Purge
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
# Public site URL (used to construct full URLs for CDN purge)
SITE_URL=https://spesialis.id

# ── CMS Revalidation Webhook ────────────────────────────────────────
# URL the Directus container uses to reach the Hono API for revalidation.
# In Docker: http://api:3000 (internal service name — default)
# Dev mode (API on host, Directus in Docker):
#   Docker Desktop: http://host.docker.internal:3000
#   Linux: http://172.17.0.1:3000
DIRECTUS_WEBHOOK_URL=http://api:3000
# E2E: disable rate limiting for tests
RATE_LIMIT_DISABLED=true
# Astro URL for CMS revalidation webhook
ASTRO_URL=http://localhost:4321
