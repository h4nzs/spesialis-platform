<clickhouse>
    <!--
      Logging config for ClickHouse in Docker.
      
      Logs to console (stdout) so they appear in `docker logs`.
      Level: warning — reduces noise while keeping important errors visible.
      
      Query log is kept with a 30-day TTL for Plausible's diagnostics,
      but unnecessary system logs (metric_log, trace_log, etc.) are
      disabled to reduce disk writes and memory usage.
    -->
    <logger>
        <level>warning</level>
        <console>true</console>
    </logger>

    <query_log replace="1">
        <database>system</database>
        <table>query_log</table>
        <flush_interval_milliseconds>7500</flush_interval_milliseconds>
        <engine>
            ENGINE = MergeTree
            PARTITION BY event_date
            ORDER BY (event_time)
            TTL event_date + interval 30 day
            SETTINGS ttl_only_drop_parts=1
        </engine>
    </query_log>

    <!-- Disable unnecessary system logs -->
    <metric_log remove="remove" />
    <asynchronous_metric_log remove="remove" />
    <query_thread_log remove="remove" />
    <text_log remove="remove" />
    <trace_log remove="remove" />
    <session_log remove="remove" />
    <part_log remove="remove" />
</clickhouse>
