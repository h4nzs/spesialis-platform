<clickhouse>
    <!--
      Memory limit config for ClickHouse in Docker.
      
      Docker cgroup limit: 768MB
      max_server_memory_usage: 650MB — leaves ~118MB headroom for:
        - Background merge operations (main cause of crashes)
        - Temporary allocations during query processing
        - System caches (mark cache, uncompressed cache)
      
      Without this limit, ClickHouse tries to use all memory within the
      cgroup (max_memory_usage = 0 = unlimited), and crashes with
      MEMORY_LIMIT_EXCEEDED when background merges spike above the limit.
      
      listen_try: 1 — prevents startup failure if a listen address
      cannot be bound (e.g., IPv6 disabled on VPS).
    -->
    <max_server_memory_usage>681574400</max_server_memory_usage>
    <listen_try>1</listen_try>
</clickhouse>
