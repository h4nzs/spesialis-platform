# =============================================================================
# Specialist Platform — Production Environment Variables
# =============================================================================
# Copy to .env.prod and fill in your values:
#   cp .env.prod.example .env.prod && nano .env.prod
#
# Then deploy:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# IMPORTANT: Keep .env.prod secure — it contains secrets!
# Never commit it to version control.
# =============================================================================

# ── Domain ────────────────────────────────────────────────────────────
DOMAIN=ahlipanggilan.id
SITE_URL=https://${DOMAIN}
APP_URL=https://${DOMAIN}
PUBLIC_API_URL=https://${DOMAIN}/api

# ── Database ──────────────────────────────────────────────────────────
DATABASE_USER=specialist
DATABASE_PASSWORD=CHANGE_ME_generate_strong_password
DATABASE_NAME=specialist

# ── Authentication ────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGIN=https://${DOMAIN}

# ── Email (SMTP) — required for password reset, notifications ─────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
SMTP_FROM=Spesialis <noreply@${DOMAIN}>

# ── Resend (alternative to SMTP) ──────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=Spesialis <noreply@${DOMAIN}>

# ── Cloudflare R2 (object storage for uploads) ────────────────────────
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY=
R2_SECRET_KEY=

# ── WhatsApp Gateway (Fonnte) ────────────────────────────────────────
WHATSAPP_API_URL=https://api.fonnte.com/send
WHATSAPP_API_KEY=

# ── Cloudflare CDN ───────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ── CMS Revalidation ─────────────────────────────────────────────────
# Generate: openssl rand -hex 16
REVALIDATION_TOKEN=CHANGE_ME_generate_token

# ── Image Registry (for CI/CD) ───────────────────────────────────────
IMAGE_REGISTRY=ghcr.io
IMAGE_OWNER=ahlipanggilan
IMAGE_TAG=latest
