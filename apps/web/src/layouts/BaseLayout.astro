---
import '../styles/global.css'
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Spesialis - Layanan Profesional</title>
    <meta name="description" content="Platform layanan jasa profesional on-demand" />
  </head>
  <body class="min-h-screen bg-background text-text font-sans antialiased">
    <header class="sticky top-0 z-50 border-b border-border bg-surface/80 backdrop-blur-md">
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <a href="/" class="text-xl font-bold tracking-tight text-primary">Spesialis</a>
        <nav class="flex items-center gap-6 text-sm font-medium text-text-muted">
          <a href="/" class="hover:text-text transition-colors">Beranda</a>
          <a href="/services" class="hover:text-text transition-colors">Layanan</a>
          <a href="/tracking" class="hover:text-text transition-colors">Lacak</a>
          <a href="/login" class="hover:text-text transition-colors">Masuk</a>
          <a
            href="/register"
            class="inline-flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-hover"
          >
            Daftar
          </a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-border bg-surface py-8 text-center text-sm text-text-muted">
      <p>&copy; {new Date().getFullYear()} Spesialis. All rights reserved.</p>
    </footer>
  </body>
</html>
