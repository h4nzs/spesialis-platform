---
import '@fontsource-variable/inter';
import '../styles/global.css'
import { AuthNav } from '../components/AuthNav.tsx'
import WhatsAppFloating from '../components/WhatsAppFloating.astro'
import Footer from '../components/homepage/Footer.astro'

export interface Props {
  title?: string
  description?: string
  ogImage?: string
  ogImageAlt?: string
  ogType?: 'website' | 'article'
  canonicalUrl?: string
  jsonLd?: Record<string, unknown>
  noindex?: boolean
  articlePublishedTime?: string
  articleModifiedTime?: string
  articleAuthor?: string
}

const {
  title = 'Ahli Panggilan - Layanan Profesional',
  description = 'Perusahaan penyedia layanan jasa profesional. Booking layanan perbaikan dan perawatan untuk kebutuhan rumah, kantor, dan bisnis Anda.',
  ogImage = '/og-default.png',
  ogImageAlt,
  ogType = 'website',
  canonicalUrl,
  jsonLd,
  noindex = false,
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
} = Astro.props

const auth = Astro.locals.auth

const siteUrl = 'https://ahlipanggilan.id'
const canonical = canonicalUrl ? `${siteUrl}${canonicalUrl}` : undefined

// ── WhatsApp settings ─────────────────────────────────────────
const apiUrl = process.env.API_URL ?? process.env.PUBLIC_API_URL ?? 'http://localhost:3000'
let whatsappPhone = ''
try {
  const res = await fetch(`${apiUrl}/api/v1/public/settings`)
  if (res.ok) {
    const body = await res.json() as { data: Record<string, string> }
    whatsappPhone = (body.data ?? body).whatsapp_phone_number ?? ''
  }
} catch {
  // Non-critical — WA button will not render
}

const waPages = ['/', '/services', '/blog', '/tracking', '/partner', '/corporate']
const showWa = whatsappPhone && waPages.some(
  (p) => Astro.url.pathname === p || (p !== '/' && Astro.url.pathname.startsWith(p + '/')),
)
---

<!DOCTYPE html>
<html lang="id" style="overflow-x:hidden">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/logo-icon.png" sizes="32x32" />
    <link rel="icon" href="/logo-icon.ico" type="image/x-icon" sizes="32x32" />
    <link rel="apple-touch-icon" href="/logo-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#2563eb" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:locale" content="id_ID" />
    <meta property="og:site_name" content="Ahli Panggilan" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical ?? siteUrl} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@ahlipanggilan_id" />
    <meta name="twitter:creator" content="@ahlipanggilan_id" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    {articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
    {articleModifiedTime && <meta property="article:modified_time" content={articleModifiedTime} />}
    {articleAuthor && <meta property="article:author" content={articleAuthor} />}

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />}
    <link rel="prefetch" href="/" />
    <link rel="prefetch" href="/services" />
    <link rel="prefetch" href="/blog" />
    <link rel="prefetch" href="/faq" />
    <link rel="prefetch" href="/partner" />
    <link rel="prefetch" href="/corporate" />
  </head>
  <body class="min-h-screen overflow-x-hidden bg-bg-page text-text-primary font-sans antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-toast focus:rounded-md focus:bg-bg-surface focus:px-4 focus:py-2 focus:text-body focus:font-medium focus:text-text-primary focus:shadow-md">
      Lewati ke konten utama
    </a>
    <header class="sticky top-0 z-navbar border-b border-border-default bg-bg-navbar/80 backdrop-blur-md">
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <a href="/" class="block shrink-0">
          <img src="/logo-dan-text-menyamping.png" alt="Ahli Panggilan" width="180" height="36" class="h-9 w-auto md:h-10" loading="eager" fetchpriority="high" />
        </a>

        <!-- ── Desktop nav (md+) ──────────────────────────────── -->
        <nav class="hidden items-center gap-4 text-sm font-medium text-text-muted md:flex md:gap-6">
          <a href="/" class="hover:text-text-primary transition-colors">Beranda</a>
          <a href="/services" class="hover:text-text-primary transition-colors">Layanan</a>
          <a href="/blog" class="hover:text-text-primary transition-colors">Blog</a>
          <a href="/partner" class="hover:text-text-primary transition-colors">Mitra</a>
          <a href="/corporate" class="hover:text-text-primary transition-colors">Corporate</a>
          <a href="/tracking" class="hover:text-text-primary transition-colors">Lacak</a>
          <AuthNav client:load initialAuth={auth} />
        </nav>

        <!-- ── Mobile: hamburger toggle + AuthNav ─────────────── -->
        <div class="flex items-center gap-2 md:hidden">
          <AuthNav client:load initialAuth={auth} />
          <label for="hamburger" class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-lg text-text-muted transition-colors hover:bg-neutral-100 hover:text-text-primary" aria-label="Buka menu navigasi">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/>
            </svg>
          </label>
        </div>
      </div>

      <!-- ── Mobile dropdown menu ─────────────────────────────── -->
      <!-- Checkbox must be a sibling of dropdown for Tailwind peer to work -->
      <input type="checkbox" id="hamburger" class="peer/hamburger sr-only" aria-label="Buka menu navigasi" />
      <div class="hidden border-t border-border-default bg-bg-surface px-4 py-3 peer-checked/hamburger:block md:hidden">
        <nav class="flex flex-col gap-1 text-body font-medium text-text-muted">
          <a href="/" class="rounded-lg px-3 py-2.5 transition-colors hover:bg-neutral-100 hover:text-text-primary">Beranda</a>
          <a href="/services" class="rounded-lg px-3 py-2.5 transition-colors hover:bg-neutral-100 hover:text-text-primary">Layanan</a>
          <a href="/blog" class="rounded-lg px-3 py-2.5 transition-colors hover:bg-neutral-100 hover:text-text-primary">Blog</a>
          <a href="/partner" class="rounded-lg px-3 py-2.5 transition-colors hover:bg-neutral-100 hover:text-text-primary">Mitra</a>
          <a href="/corporate" class="rounded-lg px-3 py-2.5 transition-colors hover:bg-neutral-100 hover:text-text-primary">Corporate</a>
          <a href="/tracking" class="rounded-lg px-3 py-2.5 transition-colors hover:bg-neutral-100 hover:text-text-primary">Lacak</a>
        </nav>
      </div>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <div id="global-footer-area">
      <Footer />
      {showWa && <WhatsAppFloating phoneNumber={whatsappPhone} />}
    </div>
    <div id="app-settings" data-whatsapp-phone={whatsappPhone || ''} style="display:none"></div>
  </body>
</html>
