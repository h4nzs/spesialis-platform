---
import BaseLayout from './BaseLayout.astro'
import { AuthGuard } from '../components/dashboard/AuthGuard.tsx'
import { Sidebar } from '../components/dashboard/Sidebar.tsx'
import { MobileBottomNav } from '../components/dashboard/MobileBottomNav.tsx'
import { NotificationBell } from '../components/dashboard/NotificationBell.tsx'
import type { UserRole } from '@ahlipanggilan/types'

export interface DashboardLayoutProps {
  title: string;
  role: UserRole | UserRole[];
}

const { title, role } = Astro.props as DashboardLayoutProps;
const auth = Astro.locals.auth;
const initialUser = auth
  ? { id: auth.userId, email: auth.userEmail, role: auth.userRole }
  : undefined;
const currentPath = Astro.url.pathname;
// Sidebar uses the user's actual role for navigation (not the allowed roles)
const sidebarRole = initialUser?.role ?? (Array.isArray(role) ? role[0] : role);
---

<BaseLayout noindex={true} hideFooter={true}>
  <AuthGuard client:load requiredRole={role} initialUser={initialUser}>
    <div class="mx-auto flex max-w-7xl gap-8 px-4 py-8 sm:px-6 lg:px-8">
      <Sidebar client:load role={sidebarRole as UserRole} currentPath={currentPath} userName={auth?.userName} userEmail={initialUser?.email} />
      <div data-sidebar-role={sidebarRole} style="display:none"></div>
      <div class="min-w-0 flex-1 pb-16">
        <div class="mb-6 flex items-center justify-between">
          <h1 class="text-h2 text-text-primary">{title}</h1>
          <NotificationBell client:load />
        </div>
        <slot />
      </div>
      <MobileBottomNav client:load role={sidebarRole as UserRole} currentPath={currentPath} />
    </div>
  </AuthGuard>
</BaseLayout>

<script>
  import { trackDashboardView } from '@spesialis/analytics'

  var role = document.querySelector('[data-sidebar-role]')?.getAttribute('data-sidebar-role') || 'unknown'
  var section = window.location.pathname.replace('/dashboard/', '').split('/')[0] || 'home'
  trackDashboardView(role, section)
</script>
