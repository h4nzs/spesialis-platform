---
import BaseLayout from './BaseLayout.astro'
import { AuthGuard } from '../components/dashboard/AuthGuard.tsx'
import { Sidebar } from '../components/dashboard/Sidebar.tsx'
import { NotificationBell } from '../components/dashboard/NotificationBell.tsx'
import type { UserRole } from '@specialist/types'

export interface DashboardLayoutProps {
  title: string;
  role: UserRole;
}

const { title, role } = Astro.props as DashboardLayoutProps;
const auth = Astro.locals.auth;
const initialUser = auth
  ? { id: auth.userId, email: auth.userEmail, role: auth.userRole }
  : undefined;
---

<BaseLayout noindex={true}>
  <AuthGuard client:load requiredRole={role} initialUser={initialUser}>
    <div class="mx-auto flex max-w-7xl gap-8 px-4 py-8 sm:px-6 lg:px-8">
      <Sidebar client:load role={role} />
      <div class="min-w-0 flex-1">
        <div class="mb-6 flex items-center justify-between">
          <h1 class="text-2xl font-bold text-text">{title}</h1>
          <NotificationBell client:load />
        </div>
        <slot />
      </div>
    </div>
  </AuthGuard>
</BaseLayout>
