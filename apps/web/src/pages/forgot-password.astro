---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ForgotPasswordForm } from '../components/ForgotPasswordForm.tsx';
---

<BaseLayout title="Lupa Password - Spesialis" description="Reset password akun Spesialis Anda. Masukkan email untuk menerima tautan reset password.">
  <div class="mx-auto flex min-h-[60vh] max-w-md items-center px-4 py-16 sm:px-6">
    <div class="w-full">
      <h1 class="text-center text-2xl font-bold text-text">Lupa Password</h1>
      <p class="mt-2 text-center text-sm text-text-muted">
        Masukkan email Anda untuk menerima link reset password
      </p>
      <div class="mt-8">
        <ForgotPasswordForm client:load />
      </div>
    </div>
  </div>
</BaseLayout>
