---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { PartnerRegistrationForm } from '../../components/PartnerRegistrationForm.tsx'
---

<BaseLayout
  title="Daftar Mitra - Spesialis"
  description="Bergabung menjadi mitra teknisi Spesialis. Dapatkan pekerjaan, atur jadwal, dan kembangkan bisnis Anda."
  canonicalUrl="/register/partner"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Beranda', item: 'https://spesialis.id' },
      { '@type': 'ListItem', position: 2, name: 'Daftar Mitra' },
    ],
  }}
>
  <div class="mx-auto max-w-lg px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-h3 font-bold text-text-primary">Daftar sebagai Mitra</h1>
    <p class="mt-1 text-body-sm text-text-secondary">
      Bergabunglah menjadi mitra Spesialis dan dapatkan pekerjaan
    </p>

    <div class="mt-8">
      <PartnerRegistrationForm client:load />
    </div>
  </div>
</BaseLayout>
