---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Kontak - Spesialis"
  description="Hubungi tim Spesialis untuk pertanyaan, kritik, saran, atau kerjasama. Kami siap membantu Anda."
  canonicalUrl="/kontak"
>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-text">Hubungi Kami</h1>
    <p class="mt-2 text-text-muted">
      Punya pertanyaan atau butuh bantuan? Tim kami siap membantu.
    </p>

    <div class="mt-10 grid gap-8 sm:grid-cols-2">
      <div class="rounded-lg border border-border bg-surface p-6">
        <h2 class="font-semibold text-text">Email</h2>
        <p class="mt-2 text-sm text-text-muted">
          <a href="mailto:hello@spesialis.id" class="text-primary hover:text-primary-hover transition-colors">
            hello@spesialis.id
          </a>
        </p>
      </div>
      <div class="rounded-lg border border-border bg-surface p-6">
        <h2 class="font-semibold text-text">WhatsApp</h2>
        <p class="mt-2 text-sm text-text-muted">
          <a href="https://wa.me/6281234567890" class="text-primary hover:text-primary-hover transition-colors" target="_blank" rel="noopener noreferrer">
            +62 812-3456-7890
          </a>
        </p>
      </div>
      <div class="rounded-lg border border-border bg-surface p-6">
        <h2 class="font-semibold text-text">Jam Operasional</h2>
        <p class="mt-2 text-sm text-text-muted">
          Senin - Sabtu: 08.00 - 20.00 WIB<br />
          Minggu: 09.00 - 17.00 WIB
        </p>
      </div>
      <div class="rounded-lg border border-border bg-surface p-6">
        <h2 class="font-semibold text-text">Lokasi</h2>
        <p class="mt-2 text-sm text-text-muted">
          Jakarta, Indonesia
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
