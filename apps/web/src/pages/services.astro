---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-text">Layanan</h1>
    <p class="mt-2 text-text-muted">Pilih layanan yang Anda butuhkan</p>

    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <article class="rounded-lg border border-border bg-surface p-6 transition-shadow hover:shadow-md">
        <h2 class="text-lg font-semibold text-text">Service AC</h2>
        <p class="mt-2 text-sm text-text-muted">Perbaikan, pembersihan, dan instalasi AC untuk rumah dan kantor.</p>
        <span class="mt-4 inline-block text-sm font-medium text-primary">Mulai dari Rp150.000</span>
      </article>
      <article class="rounded-lg border border-border bg-surface p-6 transition-shadow hover:shadow-md">
        <h2 class="text-lg font-semibold text-text">Pipa & Plumbing</h2>
        <p class="mt-2 text-sm text-text-muted">Atasi kebocoran, mampet, dan instalasi pipa air.</p>
        <span class="mt-4 inline-block text-sm font-medium text-primary">Mulai dari Rp100.000</span>
      </article>
      <article class="rounded-lg border border-border bg-surface p-6 transition-shadow hover:shadow-md">
        <h2 class="text-lg font-semibold text-text">Listrik</h2>
        <p class="mt-2 text-sm text-text-muted">Perbaikan instalasi listrik, panel, dan perangkat elektronik.</p>
        <span class="mt-4 inline-block text-sm font-medium text-primary">Mulai dari Rp100.000</span>
      </article>
    </div>
  </div>
</BaseLayout>
