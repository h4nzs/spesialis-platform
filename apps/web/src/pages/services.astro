---
import BaseLayout from '../layouts/BaseLayout.astro'
import { ServiceList } from '../components/ServiceList.tsx'
---

<BaseLayout
  title="Layanan - Spesialis"
  description="Pilih layanan jasa profesional yang Anda butuhkan — AC, plumbing, listrik, cleaning, CCTV, dan lainnya. Harga transparan, teknisi berpengalaman."
  canonicalUrl="/services"
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-text">Layanan</h1>
    <p class="mt-2 text-text-muted">Pilih layanan yang Anda butuhkan</p>

    <div class="mt-8">
      <ServiceList client:load />
    </div>
  </div>
</BaseLayout>
