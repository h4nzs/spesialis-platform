---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="404 - Halaman Tidak Ditemukan - Spesialis" description="Halaman yang Anda cari tidak ditemukan.">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-lg text-center">
      <h1 class="text-6xl font-bold text-primary">404</h1>
      <p class="mt-4 text-lg text-text-muted">Halaman yang Anda cari tidak ditemukan.</p>
      <a
        href="/"
        class="mt-6 inline-flex items-center gap-2 rounded-md bg-primary px-6 py-3 text-base font-medium text-white transition-colors hover:bg-primary-hover"
      >
        Kembali ke Beranda
      </a>
    </div>
  </div>
</BaseLayout>
