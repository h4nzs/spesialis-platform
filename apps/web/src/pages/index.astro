---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/homepage/Hero.astro'
import { ServiceExplorer } from '../components/homepage/ServiceExplorer.tsx'
import WhyChooseUs from '../components/homepage/WhyChooseUs.astro'
import Statistics from '../components/homepage/Statistics.astro'
import FeaturedServices from '../components/homepage/FeaturedServices.astro'
import Process from '../components/homepage/Process.astro'
import Testimonials from '../components/homepage/Testimonials.astro'
import Coverage from '../components/homepage/Coverage.astro'
import CorporateCTA from '../components/homepage/CorporateCTA.astro'
import LatestArticles from '../components/homepage/LatestArticles.astro'
import FAQSection from '../components/homepage/FAQSection.astro'
import FinalCTA from '../components/homepage/FinalCTA.astro'

interface ServiceItem {
  id: string;
  name: string;
  slug: string;
  shortDescription: string | null;
  basePrice: string;
  estimatedDuration: number | null;
  isFeatured: boolean | null;
}

interface CoverageArea {
  id: string;
  city: string;
}

interface ArticleItem {
  title: string;
  slug: string;
  summary: string | null;
  coverImage: string | null;
  category: string | null;
  publishedAt: string | null;
}

// SSR: fetch services, articles, and coverage areas from Hono API + CMS API
let services: ServiceItem[] = []
let articles: ArticleItem[] = []
let totalCities = 0
try {
  const [servicesRes, articlesRes, coverageRes] = await Promise.all([
    fetch(`${process.env.API_URL ?? process.env.PUBLIC_API_URL ?? 'http://localhost:3000'}/api/v1/services?limit=12`),
    fetch(`${process.env.API_URL ?? process.env.PUBLIC_API_URL ?? 'http://localhost:3000'}/api/v1/cms/articles?limit=3`),
    fetch(`${process.env.API_URL ?? process.env.PUBLIC_API_URL ?? 'http://localhost:3000'}/api/v1/public/coverage-areas`),
  ])
  if (servicesRes.ok) {
    const json = await servicesRes.json()
    services = json.data ?? []
  }
  if (articlesRes.ok) {
    const json = await articlesRes.json()
    const rawArticles = json.data ?? []
    if (Array.isArray(rawArticles)) {
      articles = (rawArticles as Array<{ title: string; slug: string; summary: string | null; cover_image: string | null; category: string | null; published_at: string | null }>).map((a) => ({
        title: a.title,
        slug: a.slug,
        summary: a.summary,
        coverImage: a.cover_image,
        category: a.category,
        publishedAt: a.published_at,
      }))
    }
  }
  if (coverageRes.ok) {
    const json = await coverageRes.json()
    const areas: CoverageArea[] = json.data ?? []
    totalCities = areas.length
  }
} catch {
  // silent — components handle empty state with fallback
}

// Fallback jika fetch gagal — pakai jumlah dari fallback Coverage.astro
if (totalCities === 0) {
  totalCities = 6 // ['Jakarta', 'Bandung', 'Tangerang', 'Bekasi', 'Depok', 'Bogor']
}
---

<BaseLayout
  title="Ahli Panggilan - Layanan Profesional Tanpa Ribet"
  description="Perusahaan penyedia layanan jasa profesional. Booking layanan AC, plumbing, listrik, cleaning, dan jasa lainnya dengan harga transparan dan garansi."
  canonicalUrl="/"
  jsonLd={{
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'WebSite',
        '@id': 'https://ahlipanggilan.id/#website',
        url: 'https://ahlipanggilan.id',
        name: 'Ahli Panggilan',
        description: 'Perusahaan penyedia layanan jasa profesional di Indonesia.',
        potentialAction: {
          '@type': 'SearchAction',
          target: {
            '@type': 'EntryPoint',
            urlTemplate: 'https://ahlipanggilan.id/services?q={search_term_string}',
          },
          'query-input': 'required name=search_term_string',
        },
      },
      {
        '@type': 'LocalBusiness',
        '@id': 'https://ahlipanggilan.id',
        name: 'Ahli Panggilan',
        url: 'https://ahlipanggilan.id',
        logo: 'https://ahlipanggilan.id/favicon.svg',
        image: 'https://ahlipanggilan.id/og-default.png',
        description: 'Perusahaan penyedia layanan jasa profesional di Indonesia.',
        areaServed: { '@type': 'Country', name: 'Indonesia' },
        offers: { '@type': 'AggregateOffer', priceCurrency: 'IDR' },
        priceRange: 'Rp50.000-Rp5.000.000',
        telephone: '+62-',
        contactPoint: {
          '@type': 'ContactPoint',
          contactType: 'customer service',
          availableLanguage: ['Indonesian'],
        },
        sameAs: [
          'https://instagram.com/ahlipanggilan.id',
          'https://facebook.com/ahlipanggilan.id',
        ],
        address: { '@type': 'PostalAddress', addressCountry: 'ID' },
      },
    ],
  }}
>
  <!-- ── Landing: Hero + Service Categories + Why Choose + Coverage ── -->
  <!-- Visible pada initial page load — desain compact seperti referensi -->
  <Hero totalServices={services.length} />
  <ServiceExplorer client:load />
  <WhyChooseUs totalServices={services.length} totalCities={totalCities} />
  <Coverage />

  <!-- ── Section tambahan (hidden, muncul saat "Lihat Selengkapnya" diklik) ── -->
  <div id="homepage-content" class="hidden">
    <FeaturedServices services={services} />
    <Process />
    <Statistics totalCities={totalCities} />
    <Testimonials />
    <CorporateCTA />
    <LatestArticles articles={articles} />
    <FAQSection />
    <FinalCTA />
  </div>

  <!-- Sembunyikan footer & WA saat awal — baru muncul via "Lihat Selengkapnya" -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var fa = document.getElementById('global-footer-area');
      if (fa) fa.style.display = 'none';
    });
  </script>

</BaseLayout>
