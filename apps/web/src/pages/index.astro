---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Spesialis - Layanan Profesional Tanpa Ribet"
  description="Platform layanan jasa profesional on-demand. Booking teknisi AC, plumbing, listrik, cleaning, dan jasa profesional lainnya dengan harga transparan dan garansi."
  canonicalUrl="/"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    '@id': 'https://spesialis.id',
    name: 'Spesialis',
    url: 'https://spesialis.id',
    logo: 'https://spesialis.id/favicon.svg',
    image: 'https://spesialis.id/og-default.png',
    description: 'Platform layanan jasa profesional on-demand di Indonesia.',
    areaServed: { '@type': 'Country', name: 'Indonesia' },
    offers: { '@type': 'AggregateOffer', priceCurrency: 'IDR' },
    priceRange: 'Rp50.000-Rp5.000.000',
    telephone: '+62-',
    contactPoint: {
      '@type': 'ContactPoint',
      contactType: 'customer service',
      availableLanguage: ['Indonesian'],
    },
    sameAs: [],
    address: { '@type': 'PostalAddress', addressCountry: 'ID' },
  }}
>
  <section class="py-20 text-center animate-fade-in">
    <h1 class="mx-auto max-w-3xl text-4xl font-bold tracking-tight text-text sm:text-5xl">
      Layanan Profesional
      <span class="text-primary"> Tanpa Ribet</span>
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-text-muted">
      Temukan teknisi dan profesional terpercaya untuk kebutuhan rumah, kantor, dan bisnis Anda.
    </p>
    <div class="mt-8 flex items-center justify-center gap-4">
      <a
        href="/services"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-6 py-3 text-base font-medium text-white transition-colors hover:bg-primary-hover"
      >
        Lihat Layanan
      </a>
      <a
        href="/tracking"
        class="inline-flex items-center gap-2 rounded-md border border-border bg-surface px-6 py-3 text-base font-medium text-text transition-colors hover:bg-background"
      >
        Lacak Booking
      </a>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-2xl font-semibold text-text">Kenapa Spesialis?</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-3">
        <div class="rounded-lg border border-border bg-surface p-6 text-center">
          <div class="text-3xl mb-3">🔧</div>
          <h3 class="font-semibold text-text">Teknisi Berpengalaman</h3>
          <p class="mt-2 text-sm text-text-muted">Semua mitra telah diverifikasi dan berpengalaman di bidangnya.</p>
        </div>
        <div class="rounded-lg border border-border bg-surface p-6 text-center">
          <div class="text-3xl mb-3">⚡</div>
          <h3 class="font-semibold text-text">Cepat & Mudah</h3>
          <p class="mt-2 text-sm text-text-muted">Booking dalam hitungan menit, tanpa perlu antre atau telepon.</p>
        </div>
        <div class="rounded-lg border border-border bg-surface p-6 text-center">
          <div class="text-3xl mb-3">🛡️</div>
          <h3 class="font-semibold text-text">Garansi Layanan</h3>
          <p class="mt-2 text-sm text-text-muted">Setiap layanan dilindungi garansi untuk ketenangan Anda.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
