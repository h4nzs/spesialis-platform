---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/homepage/Hero.astro'
import FeaturedServices from '../components/homepage/FeaturedServices.astro'
import ServiceGrid from '../components/homepage/ServiceGrid.astro'
import Benefits from '../components/homepage/Benefits.astro'
import Statistics from '../components/homepage/Statistics.astro'
import Process from '../components/homepage/Process.astro'
import Testimonials from '../components/homepage/Testimonials.astro'
import Coverage from '../components/homepage/Coverage.astro'
import PartnerCTA from '../components/homepage/PartnerCTA.astro'
import CorporateCTA from '../components/homepage/CorporateCTA.astro'
import LatestArticles from '../components/homepage/LatestArticles.astro'
import FAQSection from '../components/homepage/FAQSection.astro'
import FinalCTA from '../components/homepage/FinalCTA.astro'

interface ServiceItem {
  id: string;
  name: string;
  slug: string;
  shortDescription: string | null;
  basePrice: number;
  estimatedDuration: number | null;
  isFeatured: boolean | null;
}

interface ArticleItem {
  title: string;
  slug: string;
  summary: string | null;
  coverImage: string | null;
  category: string | null;
  publishedAt: string | null;
}

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

// SSR: fetch services and articles from Hono API (business logic) + CMS API (public content)
let services: ServiceItem[] = []
let articles: ArticleItem[] = []
try {
  const [servicesRes, articlesRes] = await Promise.all([
    fetch(`${import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'}/api/v1/services?limit=12`),
    fetch(`${import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'}/api/v1/cms/articles?limit=3`),
  ])
  if (servicesRes.ok) {
    const json = await servicesRes.json()
    services = json.data ?? []
  }
  if (articlesRes.ok) {
    const json = await articlesRes.json()
    const rawArticles = json.data ?? []
    if (Array.isArray(rawArticles)) {
      articles = (rawArticles as Array<{ title: string; slug: string; summary: string | null; cover_image: string | null; category: string | null; published_at: string | null }>).map((a) => ({
        title: a.title,
        slug: a.slug,
        summary: a.summary,
        coverImage: a.cover_image,
        category: a.category,
        publishedAt: a.published_at,
      }))
    }
  }
} catch {
  // silent — components handle empty state with fallback
}
---

<BaseLayout
  title="Spesialis - Layanan Profesional Tanpa Ribet"
  description="Platform layanan jasa profesional on-demand. Booking teknisi AC, plumbing, listrik, cleaning, dan jasa profesional lainnya dengan harga transparan dan garansi."
  canonicalUrl="/"
  jsonLd={{
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'WebSite',
        '@id': 'https://spesialis.id/#website',
        url: 'https://spesialis.id',
        name: 'Spesialis',
        description: 'Platform layanan jasa profesional on-demand di Indonesia.',
        potentialAction: {
          '@type': 'SearchAction',
          target: {
            '@type': 'EntryPoint',
            urlTemplate: 'https://spesialis.id/services?q={search_term_string}',
          },
          'query-input': 'required name=search_term_string',
        },
      },
      {
        '@type': 'LocalBusiness',
        '@id': 'https://spesialis.id',
        name: 'Spesialis',
        url: 'https://spesialis.id',
        logo: 'https://spesialis.id/favicon.svg',
        image: 'https://spesialis.id/og-default.png',
        description: 'Platform layanan jasa profesional on-demand di Indonesia.',
        areaServed: { '@type': 'Country', name: 'Indonesia' },
        offers: { '@type': 'AggregateOffer', priceCurrency: 'IDR' },
        priceRange: 'Rp50.000-Rp5.000.000',
        telephone: '+62-',
        contactPoint: {
          '@type': 'ContactPoint',
          contactType: 'customer service',
          availableLanguage: ['Indonesian'],
        },
        sameAs: [
          'https://instagram.com/spesialis.id',
          'https://facebook.com/spesialis.id',
        ],
        address: { '@type': 'PostalAddress', addressCountry: 'ID' },
      },
    ],
  }}
>
  <!-- 1. Hero + HeroSearch -->
  <Hero totalServices={services.length} />

  <!-- 2. Featured Services (curated) -->
  <FeaturedServices services={services} />

  <!-- 3. All Services Grid -->
  <ServiceGrid services={services} />

  <!-- 4. Why Choose Us -->
  <Benefits />

  <!-- 5. Statistics (trust evidence after benefits) -->
  <Statistics />

  <!-- 6. How It Works -->
  <Process />

  <!-- 7. Testimonials -->
  <Testimonials />

  <!-- 8. Coverage Area -->
  <Coverage />

  <!-- 9. Partner CTA -->
  <PartnerCTA />

  <!-- 10. Corporate CTA -->
  <CorporateCTA />

  <!-- 11. Latest Articles -->
  <LatestArticles articles={articles} />

  <!-- 12. FAQ -->
  <FAQSection />

  <!-- 13. Final CTA -->
  <FinalCTA />

</BaseLayout>
