---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout>
  <div class="flex min-h-[60vh] flex-col items-center justify-center px-4 text-center">
    <h1 class="text-6xl font-bold text-danger">500</h1>
    <p class="mt-4 text-xl text-text">Terjadi kesalahan server</p>
    <p class="mt-2 text-sm text-text-muted">Silakan coba lagi beberapa saat</p>
    <a href="/" class="mt-6 inline-flex items-center gap-2 rounded-md bg-primary px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-primary-hover">
      Kembali ke Beranda
    </a>
  </div>
</BaseLayout>
