---
import BaseLayout from '../layouts/BaseLayout.astro'
import { TrackingForm } from '../components/TrackingForm.tsx'
---

<BaseLayout>
  <div class="mx-auto max-w-2xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-text">Lacak Booking</h1>
    <p class="mt-2 text-text-muted">Masukkan nomor booking untuk melihat status terbaru</p>

    <div class="mt-8">
      <TrackingForm client:load />
    </div>
  </div>
</BaseLayout>
