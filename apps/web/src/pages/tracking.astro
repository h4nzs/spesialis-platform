---
export const prerender = false
import BaseLayout from '../layouts/BaseLayout.astro'
import { TrackingForm } from '../components/TrackingForm.tsx'
---

<BaseLayout
  title="Lacak Booking - Spesialis"
  description="Lacak status booking layanan jasa profesional Anda secara real-time. Masukkan nomor booking untuk melihat perkembangan terbaru."
  canonicalUrl="/tracking"
  jsonLd={{
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'BreadcrumbList',
        '@id': 'https://spesialis.id/tracking#breadcrumb',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Beranda', item: 'https://spesialis.id' },
          { '@type': 'ListItem', position: 2, name: 'Lacak Booking' },
        ],
      },
      {
        '@type': 'WebPage',
        name: 'Lacak Booking - Spesialis',
        description: 'Lacak status booking layanan jasa profesional secara real-time.',
        url: 'https://spesialis.id/tracking',
        breadcrumb: { '@id': 'https://spesialis.id/tracking#breadcrumb' },
      },
    ],
  }}
>
  <div class="mx-auto max-w-2xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-h2 font-bold text-text-primary">Lacak Booking</h1>
    <p class="mt-2 text-text-secondary">Masukkan nomor booking untuk melihat status terbaru</p>

    <div class="mt-8">
      <TrackingForm client:load />
    </div>
  </div>
</BaseLayout>
