---
import BaseLayout from '../layouts/BaseLayout.astro'
import { BookingForm } from '../components/BookingForm.tsx'

export const prerender = false;

const auth = Astro.locals.auth
const serviceId = Astro.url.searchParams.get('serviceId')
---

<BaseLayout
  title="Booking - Ahli Panggilan"
  description="Pesan layanan jasa profesional online. Isi form booking untuk memesan teknisi terpercaya."
  canonicalUrl={serviceId ? `/book?serviceId=${serviceId}` : '/book'}
  jsonLd={{
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'BreadcrumbList',
        '@id': 'https://ahlipanggilan.id/book#breadcrumb',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Beranda', item: 'https://ahlipanggilan.id' },
          { '@type': 'ListItem', position: 2, name: 'Layanan', item: 'https://ahlipanggilan.id/services' },
          { '@type': 'ListItem', position: 3, name: 'Booking' },
        ],
      },
      {
        '@type': 'WebPage',
        name: 'Booking - Ahli Panggilan',
        description: 'Pesan layanan jasa profesional online. Booking teknisi terpercaya untuk AC, plumbing, listrik, cleaning, dan lainnya.',
        url: 'https://ahlipanggilan.id/book',
        breadcrumb: { '@id': 'https://ahlipanggilan.id/book#breadcrumb' },
      },
    ],
  }}
>
  <div class="mx-auto max-w-2xl px-4 py-12 sm:px-6 lg:px-8">
    <nav class="mb-8 text-body-sm text-text-secondary">
      <a href="/" class="hover:text-text-primary transition-colors">Beranda</a>
      <span class="mx-2">/</span>
      <a href="/services" class="hover:text-text-primary transition-colors">Layanan</a>
      <span class="mx-2">/</span>
      <span class="text-text-primary">Booking</span>
    </nav>

    <h1 class="text-h3 font-bold text-text-primary">Pemesanan Layanan</h1>
    <p class="mt-1 text-body-sm text-text-secondary">
      Isi form di bawah untuk memesan layanan jasa profesional
    </p>

    <div class="mt-8">
      <BookingForm
        client:load
        serviceId={serviceId}
        initialAuth={auth}
      />
    </div>
  </div>
</BaseLayout>
