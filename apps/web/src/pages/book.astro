---
import BaseLayout from '../layouts/BaseLayout.astro'
import { BookingForm } from '../components/BookingForm.tsx'

export const prerender = false;

const serviceId = Astro.url.searchParams.get('serviceId')
---

<BaseLayout
  title="Booking - Spesialis"
  description="Pesan layanan jasa profesional online. Isi form booking untuk memesan teknisi terpercaya."
  canonicalUrl={serviceId ? `/book?serviceId=${serviceId}` : '/book'}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Beranda', item: 'https://spesialis.id' },
      { '@type': 'ListItem', position: 2, name: 'Layanan', item: 'https://spesialis.id/services' },
      { '@type': 'ListItem', position: 3, name: 'Booking' },
    ],
  }}
>
  <div class="mx-auto max-w-2xl px-4 py-12 sm:px-6 lg:px-8">
    <nav class="mb-8 text-sm text-text-muted">
      <a href="/" class="hover:text-text transition-colors">Beranda</a>
      <span class="mx-2">/</span>
      <a href="/services" class="hover:text-text transition-colors">Layanan</a>
      <span class="mx-2">/</span>
      <span class="text-text">Booking</span>
    </nav>

    <h1 class="text-2xl font-bold text-text">Pemesanan Layanan</h1>
    <p class="mt-1 text-sm text-text-muted">
      Isi form di bawah untuk memesan layanan jasa profesional
    </p>

    <div class="mt-8">
      <BookingForm
        client:load
        serviceId={serviceId}
      />
    </div>
  </div>
</BaseLayout>
