---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Akses Ditolak" description="Anda tidak memiliki izin untuk mengakses halaman ini.">
  <main class="flex min-h-[60vh] flex-col items-center justify-center px-4 text-center">
    <h1 class="text-display font-bold text-text-primary">403</h1>
    <p class="mt-4 text-body-lg text-text-secondary">Akses Ditolak</p>
    <p class="mt-2 text-body text-text-muted">
      Anda tidak memiliki izin untuk mengakses halaman ini.
    </p>
    <a
      href="/"
      class="mt-6 rounded-lg bg-primary px-6 py-3 text-white transition hover:bg-primary-hover"
    >
      Kembali ke Beranda
    </a>
  </main>
</BaseLayout>
