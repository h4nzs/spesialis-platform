---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Akses Ditolak" description="Anda tidak memiliki izin untuk mengakses halaman ini.">
  <main class="flex min-h-[60vh] flex-col items-center justify-center px-4 text-center">
    <h1 class="text-6xl font-bold text-gray-800">403</h1>
    <p class="mt-4 text-xl text-gray-600">Akses Ditolak</p>
    <p class="mt-2 text-gray-500">
      Anda tidak memiliki izin untuk mengakses halaman ini.
    </p>
    <a
      href="/"
      class="mt-6 rounded-lg bg-blue-600 px-6 py-3 text-white transition hover:bg-blue-700"
    >
      Kembali ke Beranda
    </a>
  </main>
</BaseLayout>
