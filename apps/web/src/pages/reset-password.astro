---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ResetPasswordForm } from '../components/ResetPasswordForm.tsx';

const token = Astro.url.searchParams.get('token');
---

<BaseLayout title="Reset Password - Spesialis" description="Buat password baru untuk akun Spesialis Anda.">
  <div class="mx-auto flex min-h-[60vh] max-w-md items-center px-4 py-16 sm:px-6">
    <div class="w-full">
      {
        token ? (
          <>
            <h1 class="text-center text-2xl font-bold text-text">Reset Password</h1>
            <p class="mt-2 text-center text-sm text-text-muted">
              Buat password baru untuk akun Anda
            </p>
            <div class="mt-8">
              <ResetPasswordForm client:load token={token} />
            </div>
          </>
        ) : (
          <>
            <h1 class="text-center text-2xl font-bold text-text">Link Tidak Valid</h1>
            <p class="mt-2 text-center text-sm text-text-muted">
              Token reset password tidak ditemukan. Pastikan Anda menggunakan link dari email.
            </p>
            <div class="mt-6 text-center">
              <a
                href="/forgot-password"
                class="text-sm font-medium text-primary hover:text-primary-hover transition-colors"
              >
                Minta link baru
              </a>
            </div>
          </>
        )
      }
    </div>
  </div>
</BaseLayout>
