---
import BaseLayout from '../layouts/BaseLayout.astro'
import { CorporateInquiryForm } from '../components/CorporateInquiryForm.tsx'
---

<BaseLayout
  title="Corporate - Ahli Panggilan"
  description="Layanan jasa profesional untuk perusahaan. Maintenance rutin, outsourcing teknisi, dan SLA untuk kebutuhan bisnis Anda."
  canonicalUrl="/corporate"
  jsonLd={{
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Beranda', item: 'https://ahlipanggilan.id' },
          { '@type': 'ListItem', position: 2, name: 'Corporate' },
        ],
      },
      {
        '@type': 'Service',
        name: 'Layanan Corporate Ahli Panggilan',
        description: 'Layanan jasa profesional untuk perusahaan — maintenance rutin, outsourcing teknisi, dan SLA untuk kebutuhan bisnis.',
        provider: { '@type': 'Organization', name: 'Ahli Panggilan' },
        areaServed: { '@type': 'Country', name: 'Indonesia' },
        audience: { '@type': 'BusinessAudience' },
      },
    ],
  }}
>
  <div class="mx-auto max-w-lg px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-h3 font-bold text-text-primary">Inquiry Perusahaan</h1>
    <p class="mt-1 text-body-sm text-text-secondary">
      Isi form di bawah untuk menghubungi tim kami
    </p>
    <div class="mt-8">
      <CorporateInquiryForm client:load />
    </div>
  </div>
</BaseLayout>
