---
import BaseLayout from '../layouts/BaseLayout.astro'
import { CorporateInquiryForm } from '../components/CorporateInquiryForm.tsx'

const benefits = [
  {
    title: 'Maintenance Rutin',
    description: 'Jadwal perawatan berkala untuk AC, listrik, plumbing, dan infrastruktur gedung. Cegah kerusakan sebelum terjadi.',
    icon: 'calendar',
  },
  {
    title: 'Outsourcing Teknisi',
    description: 'Sediakan teknisi dedicated untuk kebutuhan harian perusahaan. Cocok untuk hotel, apartemen, mall, dan perkantoran.',
    icon: 'users',
  },
  {
    title: 'SLA Garansi',
    description: 'Service Level Agreement dengan response time terjamin. Darurat? Teknisi kami siap dalam hitungan jam.',
    icon: 'shield',
  },
  {
    title: 'Laporan Berkala',
    description: 'Dapatkan laporan maintenance, biaya, dan rekomendasi secara rutin untuk pengambilan keputusan yang lebih baik.',
    icon: 'barChart',
  },
];

const services = [
  {
    title: 'Perawatan AC Central & Split',
    description: 'Maintenance rutin, cleaning, dan perbaikan untuk seluruh sistem AC gedung Anda. Termasuk AC central, split, cassette, dan VRV.',
  },
  {
    title: 'Kelistrikan Gedung',
    description: 'Instalasi, perbaikan, dan maintenance sistem kelistrikan. Dari panel listrik hingga stop kontak, kami tangani semua.',
  },
  {
    title: 'Plumbing & Sanitasi',
    description: 'Perawatan sistem pipa air bersih, air kotor, water heater, pompa air, dan sanitasi gedung secara menyeluruh.',
  },
  {
    title: 'Cleaning Service',
    description: 'Layanan kebersihan untuk kantor, apartemen, hotel, dan area komersial. Tenaga cleaning profesional dan terlatih.',
  },
  {
    title: 'Perawatan Gedung',
    description: 'Layanan tukang serbaguna untuk perbaikan ringan, pengecatan, perbaikan furnitur, dan maintenance gedung lainnya.',
  },
  {
    title: 'Konsultasi & Audit',
    description: 'Audit infrastruktur gedung, konsultasi efisiensi energi, dan rekomendasi sistem maintenance yang optimal.',
  },
];

const steps = [
  {
    number: 1,
    title: 'Ajukan Inquiry',
    description: 'Isi form pendaftaran dengan data perusahaan dan kebutuhan layanan Anda.',
  },
  {
    number: 2,
    title: 'Konsultasi Kebutuhan',
    description: 'Tim kami akan menghubungi untuk mendiskusikan kebutuhan, jadwal, dan menyusun proposal.',
  },
  {
    number: 3,
    title: 'Sign SLA',
    description: 'Kedua pihak menyepakati Service Level Agreement — scope, response time, dan biaya maintenance.',
  },
  {
    number: 4,
    title: 'Eksekusi & Monitoring',
    description: 'Tim teknisi kami menjalankan maintenance sesuai SLA. Monitoring dan laporan berkala dikirim rutin.',
  },
];

const faqs = [
  {
    q: 'Apa itu SLA dan bagaimana sistemnya?',
    a: 'SLA (Service Level Agreement) adalah kontrak layanan yang menjamin response time, waktu penyelesaian, dan standar kualitas. Kami menyediakan beberapa tier SLA yang bisa disesuaikan dengan kebutuhan perusahaan Anda.',
  },
  {
    q: 'Berapa minimal kontrak corporate?',
    a: 'Minimal kontrak adalah 3 bulan dengan komitmen layanan tertentu. Untuk kebutuhan jangka pendek atau one-time project, Anda bisa melakukan booking reguler tanpa kontrak.',
  },
  {
    q: 'Apakah tersedia teknisi yang stand by di lokasi?',
    a: 'Ya, untuk kebutuhan tertentu kami menyediakan teknisi dedicated yang stand by di lokasi selama jam operasional. Biaya disesuaikan dengan tingkat keahlian dan jam kerja.',
  },
  {
    q: 'Bagaimana sistem pembayaran corporate?',
    a: 'Pembayaran dilakukan bulanan via invoice setelah pekerjaan dilaksanakan. Tersedia sistem termin dan credit term sesuai kesepakatan dalam kontrak.',
  },
  {
    q: 'Apakah melayani perusahaan di luar Jabodetabek?',
    a: 'Saat ini kami fokus di area Jabodetabek dan Bandung. Untuk kota lainnya, kami dapat menyesuaikan secara khusus tergantung volume kebutuhan.',
  },
  {
    q: 'Bagaimana jika ada keadaan darurat di luar jadwal?',
    a: 'Layanan darurat tersedia 24/7 dengan response time sesuai SLA. Cukup hubungi hotline corporate kami, teknisi akan segera dikirim ke lokasi.',
  },
];

const iconSVGs: Record<string, string> = {
  calendar:
    '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>',
  users:
    '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  shield:
    '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>',
  'barChart':
    '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/></svg>',
};
---

<BaseLayout
  title="Corporate - Layanan Profesional untuk Perusahaan | Ahli Panggilan"
  description="Layanan jasa profesional untuk perusahaan: maintenance rutin, outsourcing teknisi, dan SLA dengan response time terjamin. Cocok untuk hotel, apartemen, mall, dan perkantoran."
  canonicalUrl="/corporate"
  jsonLd={{
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Beranda', item: 'https://ahlipanggilan.id' },
          { '@type': 'ListItem', position: 2, name: 'Corporate' },
        ],
      },
      {
        '@type': 'Service',
        name: 'Layanan Corporate Ahli Panggilan',
        description: 'Layanan jasa profesional untuk perusahaan — maintenance rutin, outsourcing teknisi, dan SLA untuk kebutuhan bisnis.',
        provider: { '@type': 'Organization', name: 'Ahli Panggilan' },
        areaServed: { '@type': 'Country', name: 'Indonesia' },
        audience: { '@type': 'BusinessAudience' },
        offers: {
          '@type': 'AggregateOffer',
          priceCurrency: 'IDR',
          description: 'Paket layanan corporate dengan harga kompetitif',
        },
      },
      {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
          '@type': 'Question',
          name: faq.q,
          acceptedAnswer: { '@type': 'Answer', text: faq.a },
        })),
      },
    ],
  }}
>
  <!-- ═══════════════════════════════════════════════════════════
       Hero Section
       ═══════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-bg-page">
    <!-- Full background hero image -->
    <img
      src="/hero-corporate.webp"
      alt=""
      class="absolute inset-0 h-full w-full object-cover object-top"
      loading="eager"
    />
    <!-- Left-to-right fade: solid bg → transparent -->
    <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-bg-page)] via-[var(--color-bg-page)]/80 to-transparent lg:via-[var(--color-bg-page)]/30" aria-hidden="true" />

    <div class="relative z-10 container-page py-16 md:py-24 lg:py-32">
      <div class="grid items-center gap-12 lg:grid-cols-11 lg:gap-16">
        <!-- Left Column -->
        <div class="lg:col-span-5">
          <p class="text-caption font-semibold uppercase tracking-[0.2em] text-primary-500">
            LAYANAN CORPORATE
          </p>
          <h1 class="mt-5 text-display-xl text-balance text-text-primary leading-[1.1]">
            Solusi Maintenance Profesional untuk <span class="text-primary-500">Perusahaan Anda</span>
          </h1>
          <p class="mt-5 max-w-lg text-body-lg text-text-secondary text-pretty leading-relaxed">
            Mulai dari perawatan AC, kelistrikan, plumbing, hingga cleaning service — kami menyediakan teknisi terpercaya dengan SLA response time terjamin.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a
              href="#inquiry"
              class="inline-flex h-12 items-center justify-center rounded-lg bg-primary-500 px-7 text-body font-semibold text-white shadow-xs transition-all duration-150 ease-out hover:bg-primary-600 hover:shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500"
            >
              Ajukan Inquiry
            </a>
            <a
              href="#services"
              class="inline-flex h-12 items-center justify-center rounded-lg border border-border-default bg-bg-surface px-7 text-body font-medium text-text-primary shadow-xs transition-all duration-150 ease-out hover:bg-bg-section hover:shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500"
            >
              Lihat Layanan
            </a>
          </div>
          <!-- Trust indicators -->
          <div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 border-t border-border-default pt-6">
            <div class="flex items-center gap-2">
              <div class="flex h-7 w-7 items-center justify-center rounded-full bg-success-50 text-success-600" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <span class="text-body-sm text-text-secondary">SLA Terjamin</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="flex h-7 w-7 items-center justify-center rounded-full bg-primary-50 text-primary-600" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <span class="text-body-sm text-text-secondary">Response Cepat</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="flex h-7 w-7 items-center justify-center rounded-full bg-warning-50 text-warning-600" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <span class="text-body-sm text-text-secondary">Teknisi Terverifikasi</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="flex h-7 w-7 items-center justify-center rounded-full bg-secondary-50 text-secondary-600" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </div>
              <span class="text-body-sm text-text-secondary">Harga Transparan</span>
            </div>
          </div>
        </div>

        <!-- Right Column — Floating Stat Cards (desktop only) -->
        <div class="hidden lg:flex lg:col-span-6 lg:flex-wrap lg:items-end lg:self-end lg:justify-center lg:gap-4 lg:pb-12">
          <div class="flex items-center gap-3 rounded-lg border border-border-default bg-white px-4 py-3 shadow-sm">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-primary-50 text-primary-600" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3"/><rect width="7" height="5" x="14" y="3"/><rect width="7" height="9" x="14" y="12"/><rect width="7" height="5" x="3" y="16"/></svg>
            </div>
            <div>
              <p class="text-h5 font-bold text-text-primary leading-none">1.000+</p>
              <p class="text-caption text-text-muted">Pesanan Selesai</p>
            </div>
          </div>
          <div class="flex items-center gap-3 rounded-lg border border-border-default bg-white px-4 py-3 shadow-sm">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-success-50 text-success-600" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div>
              <p class="text-h5 font-bold text-text-primary leading-none">100+</p>
              <p class="text-caption text-text-muted">Mitra Teknisi</p>
            </div>
          </div>
          <div class="flex items-center gap-3 rounded-lg border border-border-default bg-white px-4 py-3 shadow-sm">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-warning-50 text-warning-600" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <p class="text-h5 font-bold text-text-primary leading-none">5</p>
              <p class="text-caption text-text-muted">Kota</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       Benefits Section
       ═══════════════════════════════════════════════════════════ -->
  <section class="bg-bg-section">
    <div class="container-page py-16 md:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-overline text-primary-500 tracking-widest">KENAPA KAMI</p>
        <h2 class="mt-3 text-h2 text-text-primary">Solusi Tepat untuk Perusahaan Anda</h2>
        <p class="mt-3 text-body-lg text-text-secondary text-pretty">
          Kami memahami kebutuhan bisnis — keandalan, kecepatan, dan transparansi adalah prioritas utama.
        </p>
      </div>

      <div class="mt-14 grid gap-6 sm:grid-cols-2">
        {
          benefits.map((b) => (
            <div class="flex gap-5 rounded-xl border border-border-default bg-bg-surface p-6 md:p-8 transition-shadow duration-150 ease-out hover:shadow-xs">
              <div class="mt-1 flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-primary-50 text-primary-600" aria-hidden="true">
                <span set:html={iconSVGs[b.icon]} />
              </div>
              <div class="min-w-0">
                <h3 class="text-h5 text-text-primary">{b.title}</h3>
                <p class="mt-2 text-body text-text-secondary leading-relaxed">{b.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       Services Section
       ═══════════════════════════════════════════════════════════ -->
  <section class="bg-bg-page" id="services">
    <div class="container-page py-16 md:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-overline text-primary-500 tracking-widest">LAYANAN</p>
        <h2 class="mt-3 text-h2 text-text-primary">Layanan Corporate Kami</h2>
        <p class="mt-3 text-body-lg text-text-secondary text-pretty">
          Berbagai layanan profesional yang bisa disesuaikan dengan kebutuhan perusahaan Anda.
        </p>
      </div>

      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          services.map((s) => (
            <div class="flex flex-col rounded-xl border border-border-default bg-bg-surface p-6 transition-shadow duration-150 ease-out hover:shadow-sm">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-50 text-primary-600" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <h3 class="mt-4 text-h5 text-text-primary">{s.title}</h3>
              <p class="mt-2 flex-1 text-body text-text-secondary leading-relaxed">{s.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       How It Works Section
       ═══════════════════════════════════════════════════════════ -->
  <section class="bg-bg-section">
    <div class="container-page py-16 md:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-overline text-primary-500 tracking-widest">CARA KERJA</p>
        <h2 class="mt-3 text-h2 text-text-primary">Bagaimana Memulai?</h2>
        <p class="mt-3 text-body-lg text-text-secondary text-pretty">
          Proses mudah dan transparan — dari inquiry hingga eksekusi.
        </p>
      </div>

      <div class="mt-14 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
        {
          steps.map((step) => (
            <div class="flex flex-col items-center text-center">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary-500 text-h5 font-bold text-white">
                {step.number}
              </div>
              <h3 class="mt-5 text-h5 text-text-primary">{step.title}</h3>
              <p class="mt-2 max-w-xs text-body text-text-secondary leading-relaxed">{step.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       FAQ Section
       ═══════════════════════════════════════════════════════════ -->
  <section class="bg-bg-page">
    <div class="container-page py-16 md:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-overline text-primary-500 tracking-widest">FAQ</p>
        <h2 class="mt-3 text-h2 text-text-primary">Pertanyaan Umum Corporate</h2>
        <p class="mt-3 text-body-lg text-text-secondary text-pretty">
          Jawaban untuk pertanyaan yang sering diajukan oleh calon mitra korporasi.
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-2xl space-y-3">
        {
          faqs.map((faq) => (
            <details class="group rounded-xl border border-border-default bg-bg-surface transition-shadow duration-150 ease-out hover:shadow-xs">
              <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-body font-medium text-text-primary select-none">
                {faq.q}
                <span class="ml-4 shrink-0 text-text-muted transition-transform duration-150 ease-out group-open:rotate-180" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m6 9 6 6 6-6"/>
                  </svg>
                </span>
              </summary>
              <div class="border-t border-border-default px-6 py-4 text-body text-text-secondary leading-relaxed">
                {faq.a}
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       Inquiry Form Section
       ═══════════════════════════════════════════════════════════ -->
  <section class="bg-bg-section" id="inquiry">
    <div class="container-page py-16 md:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-overline text-primary-500 tracking-widest">DAFTAR</p>
        <h2 class="mt-3 text-h2 text-text-primary">Ajukan Inquiry Corporate</h2>
        <p class="mt-3 text-body-lg text-text-secondary text-pretty">
          Isi form di bawah dan tim kami akan menghubungi Anda dalam 1x24 jam untuk mendiskusikan kebutuhan perusahaan Anda.
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-lg">
        <CorporateInquiryForm client:load />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       Final CTA
       ═══════════════════════════════════════════════════════════ -->
  <section class="bg-primary-900">
    <div class="container-page py-20 md:py-28">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-h2 text-white text-balance">
          Siap Bekerja Sama?
        </h2>
        <p class="mt-4 text-body-lg text-primary-200 text-pretty">
          Mulai optimalkan maintenance gedung Anda dengan layanan profesional dari Ahli Panggilan.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="#inquiry"
            class="inline-flex h-12 min-w-[220px] items-center justify-center rounded-lg bg-white px-8 text-body font-semibold text-primary-700 shadow-sm transition-all duration-150 ease-out hover:bg-primary-50 hover:shadow-md focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
          >
            Ajukan Inquiry
          </a>
          <a
            href="/services"
            class="inline-flex h-12 min-w-[220px] items-center justify-center rounded-lg border border-primary-400 px-8 text-body font-medium text-primary-200 transition-all duration-150 ease-out hover:border-primary-300 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
          >
            Lihat Layanan
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
