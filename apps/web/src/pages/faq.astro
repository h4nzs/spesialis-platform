---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro'
import { FaqList } from '../components/faq/FaqList'
interface FaqItem {
  q: string
  a: string
}

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

// SSR: fetch FAQ from Hono CMS proxy for JSON-LD structured data
// FaqList client component handles visual rendering with skeleton
let faqs: FaqItem[] = []
try {
  const res = await fetch(`${apiUrl}/api/v1/cms/faq`)
  if (res.ok) {
    const json = await res.json()
    const raw = json.data ?? []
    if (Array.isArray(raw) && raw.length > 0) {
      faqs = raw.map((item: { question: string; answer: string }) => ({
        q: item.question,
        a: item.answer,
      }))
    }
  }
} catch {
  // silent — FaqList has fallback FAQs
}
---

<BaseLayout
  title="FAQ - Spesialis"
  description="Pertanyaan yang sering diajukan tentang layanan Spesialis. Temukan jawaban tentang booking, pembayaran, garansi, dan cara menjadi mitra."
  canonicalUrl="/faq"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.length > 0
      ? faqs.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        }))
      : undefined,
  }}
>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-h2 font-bold text-text-primary">Pertanyaan Umum (FAQ)</h1>
    <p class="mt-2 text-text-secondary">
      Temukan jawaban untuk pertanyaan yang sering diajukan
    </p>

    <FaqList client:load />
  </div>
</BaseLayout>
