---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro'
import { RelatedArticles } from '../../components/blog/RelatedArticles'
import type { CmsArticle } from '../../components/blog/utils'
import { renderMarkdown } from '../../lib/markdown.ts'

const { slug } = Astro.params

interface ArticleData {
  id: string
  title: string
  slug: string
  summary: string | null
  content: string | null
  coverImage: string | null
  authorName: string | null
  categoryName: string | null
  categorySlug: string | null
  publishedAt: string | null
  createdAt: string
  updatedAt: string
  metaTitle: string | null
  metaDescription: string | null
  ogTitle: string | null
  ogDescription: string | null
  ogImage: string | null
  canonicalUrl: string | null
  schemaJson: Record<string, unknown> | null
  tags: string[] | null
  isPillarContent: boolean | null
}

const apiUrl = process.env.API_URL ?? process.env.PUBLIC_API_URL ?? 'http://localhost:3000'

let article: ArticleData | null = null
let error: string | null = null

try {
  const res = await fetch(`${apiUrl}/api/v1/cms/articles/${slug!}`)
  if (res.ok) {
    const json = await res.json()
    const raw: CmsArticle | undefined = json.data ?? undefined
    if (raw) {
      const r = raw as CmsArticle & {
        meta_title?: string | null
        meta_description?: string | null
        og_title?: string | null
        og_description?: string | null
        og_image?: string | null
        canonical_url?: string | null
        schema_json?: Record<string, unknown> | null
      }
      article = {
        id: r.id,
        title: r.title,
        slug: r.slug,
        summary: r.summary,
        content: r.content,
        coverImage: r.cover_image,
        authorName: r.author,
        categoryName: r.category,
        categorySlug: r.category?.toLowerCase().replace(/\s+/g, '-') ?? null,
        publishedAt: r.published_at,
        createdAt: r.date_created ?? r.published_at ?? '',
        updatedAt: r.date_updated ?? r.published_at ?? '',
        metaTitle: r.meta_title ?? null,
        metaDescription: r.meta_description ?? null,
        ogTitle: r.og_title ?? null,
        ogDescription: r.og_description ?? null,
  ogImage: r.og_image ?? null,
  canonicalUrl: r.canonical_url ?? null,
  schemaJson: r.schema_json ?? null,
  tags: r.tags ?? null,
      isPillarContent: r.is_pillar_content ?? false,
      }
    } else {
      error = 'Artikel tidak ditemukan'
    }
  } else {
    error = 'Artikel tidak ditemukan'
  }
} catch (e) {
  error = e instanceof Error ? e.message : 'Gagal memuat artikel'
}

// Build the JSON-LD graph: default schemas + optional custom schema
const defaultJsonLd: Record<string, unknown> | undefined = article
  ? {
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'BreadcrumbList',
          itemListElement: [
            { '@type': 'ListItem', position: 1, name: 'Beranda', item: 'https://ahlipanggilan.id' },
            { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://ahlipanggilan.id/blog' },
            { '@type': 'ListItem', position: 3, name: article.title },
          ],
        },
        {
          '@type': 'Article',
          headline: article.title,
          description: article.summary,
          image: article.coverImage
            ? {
                '@type': 'ImageObject',
                url: article.coverImage,
                representativeOfPage: true,
              }
            : undefined,
          author: article.authorName
            ? { '@type': 'Person', name: article.authorName }
            : { '@type': 'Organization', name: 'Ahli Panggilan' },
          datePublished: article.publishedAt,
          dateModified: article.updatedAt,
          publisher: {
            '@type': 'Organization',
            name: 'Ahli Panggilan',
            url: 'https://ahlipanggilan.id',
          },
          mainEntityOfPage: {
            '@type': 'WebPage',
            '@id': article.canonicalUrl
              ? `https://ahlipanggilan.id${article.canonicalUrl.startsWith('/') ? article.canonicalUrl : `/${article.canonicalUrl}`}`
              : `https://ahlipanggilan.id/blog/${article.slug}`,
          },
          ...(article.tags && article.tags.length > 0
            ? { keywords: article.tags.join(', ') }
            : {}),
        },
      ],
    }
  : undefined;

// Auto-inject CollectionPage schema for pillar content (AEO/GEO optimization)
const pillarCollectionSchema = article?.isPillarContent
  ? {
      '@type': 'CollectionPage',
      mainEntity: {
        '@type': 'Article',
        headline: article.title,
        inLanguage: 'id-ID',
      },
      about: {
        '@type': 'Thing',
        name: article.categoryName ?? article.title,
      },
    }
  : null;

// Merge custom schemaJson into the graph if present
let jsonLdPayload = defaultJsonLd;
if (article?.schemaJson && defaultJsonLd) {
  const custom = article.schemaJson;
  const baseGraph = defaultJsonLd['@graph'] as Record<string, unknown>[];
  if (custom['@graph']) {
    // Custom schema is a graph — merge items
    jsonLdPayload = {
      '@context': 'https://schema.org',
      '@graph': [...baseGraph, ...(custom['@graph'] as Record<string, unknown>[])],
    };
  } else if (custom['@type']) {
    // Single schema object — add to graph
    jsonLdPayload = {
      '@context': 'https://schema.org',
      '@graph': [...baseGraph, custom],
    };
  }
}

// Append pillar CollectionPage if applicable
if (pillarCollectionSchema && jsonLdPayload) {
  const baseGraph = jsonLdPayload['@graph'] as Record<string, unknown>[];
  jsonLdPayload = {
    '@context': 'https://schema.org',
    '@graph': [...baseGraph, pillarCollectionSchema],
  };
}

// RichTextEditor produces HTML; renderMarkdown expects Markdown.
// Detect HTML (starts with '<') and render directly, else convert from Markdown.
const contentHtml = article?.content
  ? (article.content.trim().startsWith('<') ? article.content : renderMarkdown(article.content))
  : '';
---

{
  article ? (
    <BaseLayout
      title={article.metaTitle ?? `${article.title} - Blog Ahli Panggilan`}
      description={article.metaDescription ?? (article.summary ?? `Baca artikel ${article.title} di Blog Ahli Panggilan`)}
      canonicalUrl={article.canonicalUrl ?? `/blog/${article.slug}`}
      ogImage={article.ogImage ?? article.coverImage ?? undefined}
      ogType="article"
      ogImageAlt={article.title}
      articlePublishedTime={article.publishedAt ?? undefined}
      articleModifiedTime={article.updatedAt ?? undefined}
      articleAuthor={article.authorName ?? undefined}
      jsonLd={jsonLdPayload}
    >
      <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
        <nav class="mb-8 text-body-sm text-text-secondary">
          <a href="/" class="hover:text-text-primary transition-colors">Beranda</a>
          <span class="mx-2">/</span>
          <a href="/blog" class="hover:text-text-primary transition-colors">Blog</a>
          <span class="mx-2">/</span>
          <span class="text-text-primary">{article.title}</span>
        </nav>

        {article.coverImage && (
          <img
            src={article.coverImage}
            alt={article.title}
            loading="lazy"
            decoding="async"
            width="800"
            height="450"
            class="mb-8 w-full rounded-xl object-cover"
          />
        )}

        <div class="flex flex-wrap items-center gap-3 text-body-sm text-text-secondary">
          {article.categoryName && (
            <span class="rounded-full bg-primary/10 px-3 py-1 text-caption font-medium text-primary">
              {article.categoryName}
            </span>
          )}
          {article.authorName && <span>Oleh {article.authorName}</span>}
          {article.publishedAt && (
            <time datetime={article.publishedAt}>
              {new Date(article.publishedAt).toLocaleDateString('id-ID', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
          )}
        </div>

        <h1 class="mt-4 text-h2 font-bold text-text-primary">{article.title}</h1>

        {contentHtml && (
          <div class="prose prose-gray mt-8 max-w-none" set:html={contentHtml} />
        )}

        <div class="mt-12 border-t border-border-default pt-6">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-primary-hover transition-colors"
          >
            &larr; Kembali ke Blog
          </a>
        </div>

        <RelatedArticles currentSlug={slug!} categorySlug={article.categorySlug} client:visible />
      </div>
    </BaseLayout>
  ) : (
    <BaseLayout
      title={error ? 'Artikel Tidak Ditemukan - Blog Ahli Panggilan' : 'Memuat... - Blog Ahli Panggilan'}
      description={error ?? 'Memuat artikel'}
    >
      <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-lg text-center">
          {error ? (
            <>
              <h1 class="text-h3 font-bold text-text-primary">Artikel Tidak Ditemukan</h1>
              <p class="mt-2 text-text-secondary">{error}</p>
              <a
                href="/blog"
                class="mt-6 inline-flex items-center gap-2 rounded-md bg-primary px-6 py-3 text-base font-medium text-white transition-colors hover:bg-primary-hover"
              >
                Lihat Semua Artikel
              </a>
            </>
          ) : (
            <>
              <div class="h-8 w-48 mx-auto rounded bg-bg-surface animate-pulse" />
              <div class="mt-4 h-4 w-full rounded bg-border animate-pulse" />
              <div class="mt-8 h-10 w-40 mx-auto rounded bg-border animate-pulse" />
            </>
          )}
        </div>
      </div>
    </BaseLayout>
  )
}
