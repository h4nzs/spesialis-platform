/** Build HowTo schema steps array from category slug */
function buildHowToSteps(categorySlug: string | null): HowToStepItem[] {
  const steps = categorySlug ? HOWTO_STEPS_BY_CATEGORY[categorySlug] : undefined
  if (steps) return steps
  // Generic fallback — digunakan jika kategori tidak dikenali
  return [
    { name: 'Pesan Layanan', text: 'Pilih layanan yang Anda butuhkan dan isi data pemesanan melalui website Ahli Panggilan. Sertakan detail pekerjaan, jadwal, dan alamat.' },
    { name: 'Konfirmasi Pesanan', text: 'Tim Ahli Panggilan akan mengonfirmasi pesanan Anda dan mempersiapkan teknisi yang sesuai dengan kebutuhan.' },
    { name: 'Teknisi Datang ke Lokasi', text: 'Teknisi berpengalaman akan datang ke lokasi Anda sesuai jadwal yang telah disepakati.' },
    { name: 'Pelaksanaan Pekerjaan', text: 'Teknisi melaksanakan pekerjaan sesuai standar prosedur dengan peralatan profesional.' },
    { name: 'Pembayaran', text: 'Lakukan pembayaran setelah pekerjaan selesai. Tersedia Transfer Bank, QRIS, E-Wallet, atau Cash.' },
  ]
}

// ── Build JSON-LD Graph ────────────────────────────────────────
const jsonLdGraph: Record<string, unknown>[] = [];

if (service) {
  jsonLdGraph.push({
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Beranda', item: 'https://ahlipanggilan.id' },
      { '@type': 'ListItem', position: 2, name: 'Layanan', item: 'https://ahlipanggilan.id/services' },
      { '@type': 'ListItem', position: 3, name: service?.name ?? 'Detail Layanan' },
    ],
  })
  
  const serviceSchema: Record<string, unknown> = {
    '@type': 'Service',
    name: service.name,
    description: service.shortDescription,
    provider: { '@type': 'Organization', name: 'Ahli Panggilan' },
    areaServed: coverageCities.map((city) => ({
      '@type': 'City',
      name: city,
    })),
    offers: {
      '@type': 'Offer',
      price: service.basePrice,
      priceCurrency: 'IDR',
      availability: 'https://schema.org/InStock',
    },
  }

  if (reviews && reviews.aggregate.totalReviews > 0) {
    serviceSchema.aggregateRating = {
      '@type': 'AggregateRating',
      ratingValue: reviews.aggregate.averageRating,
      reviewCount: reviews.aggregate.totalReviews,
      bestRating: 5,
      worstRating: 1,
    }
    serviceSchema.review = reviews.items.map((r) => ({
      '@type': 'Review',
      reviewRating: {
        '@type': 'Rating',
        ratingValue: Number(r.rating),
        bestRating: 5,
      },
      reviewBody: r.review,
      datePublished: r.createdAt,
    }))
  }

  jsonLdGraph.push(serviceSchema)

  // ── Add FAQPage schema for AEO ────────────────────────────
  if (serviceFaqs.length > 0) {
    jsonLdGraph.push({
      '@type': 'FAQPage',
      mainEntity: serviceFaqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    })
  }

  // ── Add HowTo schema for AEO ─────────────────────────────
  const howToSteps = buildHowToSteps(catSlug)
  const howToSchema: Record<string, unknown> = {
    '@type': 'HowTo',
    name: `Cara Memesan ${service.name}`,
    description: `Panduan langkah demi langkah untuk memesan dan mendapatkan layanan ${service.name} dari Ahli Panggilan.`,
    step: howToSteps.map((step, i) => ({
      '@type': 'HowToStep',
      position: i + 1,
      name: step.name,
      itemListElement: [
        {
          '@type': 'HowToDirection',
          text: step.text,
        },
      ],
    })),
  }
  if (service.estimatedDuration) {
    howToSchema.totalTime = `PT${service.estimatedDuration}M`
  }
  jsonLdGraph.push(howToSchema)
}

const jsonLdPayload = service
  ? { '@context': 'https://schema.org', '@graph': jsonLdGraph }
  : undefined
---

<BaseLayout
  title={service ? `${service.name} - Ahli Panggilan` : error ? 'Layanan Tidak Ditemukan - Ahli Panggilan' : 'Memuat... - Ahli Panggilan'}
  description={service?.shortDescription ?? error ?? 'Memuat detail layanan'}
  canonicalUrl={service ? `/services/${service.slug}` : '/services'}
  ogImage={service?.thumbnail ?? undefined}
  ogImageAlt={service?.name ?? undefined}
  jsonLd={jsonLdPayload}
>
  <ServiceDetail slug={slug!} initialFaqs={serviceFaqs} initialRelated={relatedServices} client:load />
</BaseLayout>

