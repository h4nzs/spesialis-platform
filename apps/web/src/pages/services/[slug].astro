---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro'
import { ServiceDetail } from '../../components/services/ServiceDetail'
import type { ServiceData, ReviewData } from '../../components/services/utils'

const { slug } = Astro.params

// SSR: fetch service + reviews for JSON-LD structured data
// ServiceDetail client component handles visual rendering with skeleton
let service: ServiceData | null = null
let reviews: ReviewData | null = null
let error: string | null = null

try {
  const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
  const [serviceRes, reviewsRes] = await Promise.all([
    fetch(`${apiUrl}/api/v1/services/${slug}`),
    fetch(`${apiUrl}/api/v1/services/${slug}/reviews`),
  ])
  if (!serviceRes.ok) throw new Error('Layanan tidak ditemukan')
  const serviceJson = await serviceRes.json()
  service = serviceJson.data
  if (reviewsRes.ok) {
    const reviewsJson = await reviewsRes.json()
    reviews = reviewsJson.data
  }
} catch (e) {
  error = e instanceof Error ? e.message : 'Gagal memuat layanan'
}

const jsonLdGraph: Record<string, unknown>[] = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Beranda', item: 'https://spesialis.id' },
      { '@type': 'ListItem', position: 2, name: 'Layanan', item: 'https://spesialis.id/services' },
      { '@type': 'ListItem', position: 3, name: service?.name },
    ],
  },
]

if (service) {
  const serviceSchema: Record<string, unknown> = {
    '@type': 'Service',
    name: service.name,
    description: service.shortDescription,
    provider: { '@type': 'Organization', name: 'Spesialis' },
    offers: {
      '@type': 'Offer',
      price: service.basePrice,
      priceCurrency: 'IDR',
      availability: 'https://schema.org/InStock',
    },
  }

  if (reviews && reviews.aggregate.totalReviews > 0) {
    serviceSchema.aggregateRating = {
      '@type': 'AggregateRating',
      ratingValue: reviews.aggregate.averageRating,
      reviewCount: reviews.aggregate.totalReviews,
      bestRating: 5,
      worstRating: 1,
    }
    serviceSchema.review = reviews.items.map((r) => ({
      '@type': 'Review',
      reviewRating: {
        '@type': 'Rating',
        ratingValue: Number(r.rating),
        bestRating: 5,
      },
      reviewBody: r.review,
      datePublished: r.createdAt,
    }))
  }

  jsonLdGraph.push(serviceSchema)
}
---

<BaseLayout
  title={service ? `${service.name} - Spesialis` : error ? 'Layanan Tidak Ditemukan - Spesialis' : 'Memuat... - Spesialis'}
  description={service?.shortDescription ?? error ?? 'Memuat detail layanan'}
  canonicalUrl={service ? `/services/${service.slug}` : '/services'}
  ogImage={service?.thumbnail ?? undefined}
  jsonLd={service ? { '@context': 'https://schema.org', '@graph': jsonLdGraph } : undefined}
>
  <ServiceDetail slug={slug!} client:load />
</BaseLayout>

