---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro'
import { formatCurrency } from '@specialist/shared'

const { slug } = Astro.params

interface ServiceData {
  id: string
  name: string
  slug: string
  shortDescription: string | null
  description: string | null
  basePrice: number
  estimatedDuration: number | null
  warrantyDays: number | null
  thumbnail: string | null
  isFeatured: boolean | null
}

let service: ServiceData | null = null
let error: string | null = null

try {
  const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
  const res = await fetch(`${apiUrl}/api/v1/services/${slug}`)
  if (!res.ok) throw new Error('Layanan tidak ditemukan')
  const json = await res.json()
  service = json.data
} catch (e) {
  error = e instanceof Error ? e.message : 'Gagal memuat layanan'
}
---

{
  service ? (
    <BaseLayout
      title={`${service.name} - Spesialis`}
      description={service.shortDescription ?? `Pesan layanan ${service.name} dari Spesialis. Harga transparan, teknisi berpengalaman.`}
      canonicalUrl={`/services/${service.slug}`}
      ogImage={service.thumbnail ?? undefined}
      jsonLd={{
        '@context': 'https://schema.org',
        '@graph': [
          {
            '@type': 'BreadcrumbList',
            itemListElement: [
              { '@type': 'ListItem', position: 1, name: 'Beranda', item: 'https://spesialis.id' },
              { '@type': 'ListItem', position: 2, name: 'Layanan', item: 'https://spesialis.id/services' },
              { '@type': 'ListItem', position: 3, name: service.name },
            ],
          },
          {
            '@type': 'Service',
            name: service.name,
            description: service.shortDescription,
            provider: { '@type': 'Organization', name: 'Spesialis' },
            offers: {
              '@type': 'Offer',
              price: service.basePrice,
              priceCurrency: 'IDR',
              availability: 'https://schema.org/InStock',
            },
          },
        ],
      }}
    >
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <nav class="mb-8 text-sm text-text-muted">
          <a href="/" class="hover:text-text transition-colors">Beranda</a>
          <span class="mx-2">/</span>
          <a href="/services" class="hover:text-text transition-colors">Layanan</a>
          <span class="mx-2">/</span>
          <span class="text-text">{service.name}</span>
        </nav>

        <div class="grid gap-10 lg:grid-cols-5">
          <div class="lg:col-span-3">
            <h1 class="text-3xl font-bold text-text">{service.name}</h1>
            {service.shortDescription && (
              <p class="mt-3 text-lg text-text-muted">{service.shortDescription}</p>
            )}
            {service.description && (
              <div class="mt-6 space-y-4 text-text">
                {service.description.split('\n').map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
            )}
            <div class="mt-8 flex flex-wrap gap-6 text-sm">
              {service.estimatedDuration && (
                <div class="rounded-lg border border-border bg-surface px-4 py-3">
                  <span class="block text-xs text-text-muted">Estimasi</span>
                  <span class="font-semibold text-text">&plusmn;{service.estimatedDuration} menit</span>
                </div>
              )}
              {service.warrantyDays && (
                <div class="rounded-lg border border-border bg-surface px-4 py-3">
                  <span class="block text-xs text-text-muted">Garansi</span>
                  <span class="font-semibold text-text">{service.warrantyDays} hari</span>
                </div>
              )}
            </div>
          </div>

          <div class="lg:col-span-2">
            <div class="sticky top-24 rounded-xl border border-border bg-surface p-6 shadow-xs">
              <div class="flex items-baseline gap-2">
                <span class="text-3xl font-bold text-primary">
                  {formatCurrency(service.basePrice)}
                </span>
                <span class="text-sm text-text-muted">/ sekali</span>
              </div>
              {service.estimatedDuration && (
                <p class="mt-2 text-sm text-text-muted">
                  Estimasi pengerjaan &plusmn;{service.estimatedDuration} menit
                </p>
              )}
              <ul class="mt-4 space-y-2 text-sm text-text-muted">
                <li class="flex items-center gap-2">
                  <span class="text-success">&#10003;</span> Teknisi berpengalaman
                </li>
                <li class="flex items-center gap-2">
                  <span class="text-success">&#10003;</span> Harga transparan
                </li>
                <li class="flex items-center gap-2">
                  <span class="text-success">&#10003;</span> Garansi layanan
                </li>
              </ul>
              <a
                href={`/book?serviceId=${service.id}`}
                class="mt-6 flex w-full items-center justify-center gap-2 rounded-md bg-primary px-6 py-3 text-base font-medium text-white transition-colors hover:bg-primary-hover"
              >
                Pesan Sekarang
              </a>
            </div>
          </div>
        </div>
      </div>
    </BaseLayout>
  ) : (
    <BaseLayout
      title={error ? 'Layanan Tidak Ditemukan - Spesialis' : 'Memuat... - Spesialis'}
      description={error ?? 'Memuat detail layanan'}
    >
      <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-lg text-center">
          {error ? (
            <>
              <h1 class="text-2xl font-bold text-text">Layanan Tidak Ditemukan</h1>
              <p class="mt-2 text-text-muted">{error}</p>
              <a
                href="/services"
                class="mt-6 inline-flex items-center gap-2 rounded-md bg-primary px-6 py-3 text-base font-medium text-white transition-colors hover:bg-primary-hover"
              >
                Lihat Semua Layanan
              </a>
            </>
          ) : (
            <>
              <div class="h-8 w-48 mx-auto rounded bg-border animate-pulse" />
              <div class="mt-4 h-4 w-full rounded bg-border animate-pulse" />
              <div class="mt-8 h-10 w-40 mx-auto rounded bg-border animate-pulse" />
            </>
          )}
        </div>
      </div>
    </BaseLayout>
  )
}
