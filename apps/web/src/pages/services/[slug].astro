---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro'
import { ServiceDetail } from '../../components/services/ServiceDetail'
import type { ServiceData, ReviewData, FaqItem, RelatedServiceItem } from '../../components/services/utils'
import { inferCategorySlug } from '@ahlipanggilan/shared'

const { slug } = Astro.params

// ── SSR data fetching ───────────────────────────────────────────
// Fetch service + reviews + category FAQs for JSON-LD structured data
// ServiceDetail client component handles visual rendering with skeleton
let service: ServiceData | null = null
let reviews: ReviewData | null = null
let error: string | null = null
let serviceFaqs: FaqItem[] = []
let catSlug: string | null = null
let relatedServices: RelatedServiceItem[] = []

try {
  const apiUrl = process.env.PUBLIC_API_URL ?? process.env.API_URL ?? 'http://localhost:3000'
  const [serviceRes, reviewsRes] = await Promise.all([
    fetch(`${apiUrl}/api/v1/services/${slug}`),
    fetch(`${apiUrl}/api/v1/services/${slug}/reviews`),
  ])
  if (!serviceRes.ok) throw new Error('Layanan tidak ditemukan')
  const serviceJson = await serviceRes.json()
  service = serviceJson.data
  if (reviewsRes.ok) {
    const reviewsJson = await reviewsRes.json()
    reviews = reviewsJson.data
  }

  // ── Fetch coverage areas for areaServed JSON-LD ────────────
  let coverageCities: string[] = [];
  try {
    const covRes = await fetch(`${apiUrl}/api/v1/cms/coverage-areas`);
    if (covRes.ok) {
      const covJson = await covRes.json();
      const rawCities: Array<{ city: string }> = covJson.data ?? [];
      coverageCities = rawCities.map((c) => c.city);
    }
  } catch {
    // Silent — areaServed will be omitted
  }

  // ── Fetch category slug for AEO + HowTo ──────────────────
  let matchedCategorySlug: string | null = null
  if (service?.categoryId) {
    try {
      const catRes = await fetch(`${apiUrl}/api/v1/service-categories`)
      if (catRes.ok) {
        const catJson = await catRes.json()
        const categories: Array<{ id: string; slug: string }> = catJson.data ?? []
        const cat = categories.find((c) => c.id === service!.categoryId)
        if (cat?.slug) {
          matchedCategorySlug = cat.slug
        }
      }
    } catch {
      // Silent — fall back to generated FAQ + generic HowTo below
    }
  }

  // ── Fetch category-specific FAQs for AEO ───────────────────
  if (matchedCategorySlug) {
    try {
      const faqRes = await fetch(
        `${apiUrl}/api/v1/cms/faq?category=${matchedCategorySlug}`,
      )
      if (faqRes.ok) {
        const faqJson = await faqRes.json()
        const rawFaqs: Array<{ question: string; answer: string }> = faqJson.data ?? []
        if (rawFaqs.length > 0) {
          serviceFaqs = rawFaqs.map((f) => ({ question: f.question, answer: f.answer }))
        }
      }
    } catch {
      // Silent — fall back to generated FAQs below
    }
  }

  // ── Fallback: auto-generate FAQs if none from CMS ─────────
  if (service && serviceFaqs.length === 0) {
    serviceFaqs = [
      {
        question: `Bagaimana cara memesan layanan ${service.name}?`,
        answer: `Anda dapat memesan layanan ${service.name} melalui website Ahli Panggilan di halaman booking. Pilih layanan, isi data diri, jadwal, dan alamat. Tim kami akan mengonfirmasi pesanan Anda dalam waktu singkat.`,        
      },
      {
        question: `Berapa biaya layanan ${service.name}?`,
        answer: `Biaya layanan ${service.name} adalah ${service.basePrice}. Harga sudah transparan tanpa biaya tersembunyi. Untuk kebutuhan khusus atau area di luar cakupan, tim kami akan memberikan penawaran harga setelah survey.`,
      },
      {
        question: `Apakah ada garansi untuk layanan ${service.name}?`,
        answer: `Ya, setiap layanan ${service.name} dilindungi garansi kepuasan Ahli Panggilan. Jika hasil pekerjaan tidak sesuai standar, kami akan menindaklanjuti tanpa biaya tambahan.`,
      },
      {
        question: `Apakah teknisi ${service.name} sudah berpengalaman?`,
        answer: `Ya, setiap teknisi Ahli Panggilan telah melalui proses verifikasi dan memiliki pengalaman di bidangnya. Kami memastikan hanya teknisi berkualitas dan terpercaya yang melayani Anda.`,
      },
      {
        question: `Bagaimana cara pembayaran untuk layanan ${service.name}?`,
        answer: `Pembayaran dapat dilakukan melalui Transfer Bank, QRIS, E-Wallet, atau Cash. Pembayaran dilakukan setelah pekerjaan selesai sesuai kesepakatan.`,
      },
    ]
  }

  // ── Fetch related services from same category (internal linking) ─
  if (service?.categoryId) {
    try {
      const relatedRes = await fetch(
        `${apiUrl}/api/v1/services?categoryId=${service.categoryId}&limit=6`,
      )
      if (relatedRes.ok) {
        const relatedJson = await relatedRes.json()
        const raw: RelatedServiceItem[] = relatedJson.data ?? []
        // Exclude the current service from related list
        relatedServices = raw.filter((r) => r.slug !== service!.slug)
      }
    } catch {
      // Silent — related services section will not appear
    }
  }

  // ── Determine category slug for HowTo schema ─────────────
  catSlug = matchedCategorySlug ?? (service?.name ? inferCategorySlug(service.name) : null)
} catch (e) {
  error = e instanceof Error ? e.message : 'Gagal memuat layanan'
}

// ── HowTo steps per category ────────────────────────────────────
