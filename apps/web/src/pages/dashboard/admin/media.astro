---
import DashboardLayout from '../../../layouts/DashboardLayout.astro'
import { AdminMedia } from '../../../components/dashboard/admin/AdminMedia'
---

<DashboardLayout title="Media" canonicalUrl="/dashboard/admin/media">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-h2 text-text-primary">Media Library</h1>
        <p class="mt-1 text-body-sm text-text-secondary">
          Kelola file dan gambar yang diupload ke platform
        </p>
      </div>
    </div>
    <AdminMedia client:load />
  </div>
</DashboardLayout>
