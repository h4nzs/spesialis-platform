---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro'
import { ClientRouter } from 'astro:transitions'
import { ArticleGrid } from '../components/blog/ArticleGrid'
interface ArticleFeedItem {
  title: string
  slug: string
  publishedAt: string | null
  authorName: string | null
  category: string | null
}

interface CategoryItem {
  slug: string
  name: string
}

const activeCategory = Astro.url.searchParams.get('kategori')

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

// SSR: fetch articles from Hono CMS proxy for JSON-LD structured data + category extraction
// ArticleGrid client component handles the visual rendering with skeleton loading
let articlesForSeo: ArticleFeedItem[] = []
let categories: CategoryItem[] = []
try {
  const res = await fetch(`${apiUrl}/api/v1/cms/articles?limit=20`)
  if (res.ok) {
    const json = await res.json()
    const raw = json.data ?? []
    if (Array.isArray(raw) && raw.length > 0) {
      articlesForSeo = raw.map((a: { title: string; slug: string; published_at: string | null; author: string | null; category: string | null }) => ({
        title: a.title,
        slug: a.slug,
        publishedAt: a.published_at,
        authorName: a.author,
        category: a.category,
      }))
      const catMap = new Map<string, string>()
      for (const a of raw) {
        if (a.category) {
          const slug = a.category.toLowerCase().replace(/\s+/g, '-')
          catMap.set(slug, a.category)
        }
      }
      categories = Array.from(catMap.entries()).map(([slug, name]) => ({ slug, name }))
    }
  }
} catch {
  // silent
}

const activeCategoryName = activeCategory
  ? categories.find((c) => c.slug === activeCategory)?.name ?? null
  : null
---

<ClientRouter />

<BaseLayout
  title={activeCategoryName ? `${activeCategoryName} - Blog Spesialis` : 'Blog - Spesialis'}
  description={activeCategoryName ? `Artikel kategori ${activeCategoryName} — tips seputar layanan profesional, perawatan rumah, dan solusi bisnis dari Spesialis.` : 'Artikel dan tips seputar layanan profesional, perawatan rumah, dan solusi bisnis dari Spesialis.'}
  canonicalUrl={activeCategory ? `/blog?kategori=${activeCategory}` : '/blog'}
  jsonLd={{
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Beranda', item: 'https://spesialis.id' },
          { '@type': 'ListItem', position: 2, name: 'Blog' },
        ],
      },
      {
        '@type': 'Blog',
        name: 'Blog Spesialis',
        description: 'Artikel dan tips seputar layanan profesional, perawatan rumah, dan solusi bisnis.',
        url: 'https://spesialis.id/blog',
        blogPost: articlesForSeo.map((a) => ({
          '@type': 'BlogPosting',
          headline: a.title,
          url: `https://spesialis.id/blog/${a.slug}`,
          datePublished: a.publishedAt,
          author: a.authorName ? { '@type': 'Person', name: a.authorName } : undefined,
        })).filter((p) => p.datePublished),
      },
    ],
  }}
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 motion-safe:animate-fade-in">
    <nav class="mb-8 text-body-sm text-text-secondary">
      <a href="/" class="hover:text-text-primary transition-colors">Beranda</a>
      <span class="mx-2">/</span>
      <a href="/blog" class="hover:text-text-primary transition-colors">Blog</a>
      {activeCategoryName && (
        <>
          <span class="mx-2">/</span>
          <span class="text-text-primary">{activeCategoryName}</span>
        </>
      )}
    </nav>

    <div class="flex items-baseline gap-3">
      <h1 class="text-h2 font-bold text-text-primary">
        {activeCategoryName || 'Blog'}
      </h1>
      {activeCategoryName && (
        <span class="text-body-sm text-text-secondary">Blog</span>
      )}
    </div>
    <p class="mt-2 text-text-secondary">
      {activeCategoryName ? `Artikel seputar ${activeCategoryName.toLowerCase()}` : 'Artikel dan tips seputar layanan profesional'}
    </p>

    {categories.length > 0 && (
      <div class="mt-6 flex flex-wrap gap-2">
        <a
          href="/blog"
          class={`rounded-full px-4 py-1.5 text-body-sm font-medium transition-colors ${
            !activeCategory
              ? 'bg-primary text-white'
              : 'border border-border-default bg-bg-surface text-text-secondary hover:text-text-primary'
          }`}
        >
          Semua
        </a>
        {categories.map((cat) => (          <a
          href={`/blog?kategori=${cat.slug}`}
          class={`rounded-full px-4 py-1.5 text-body-sm font-medium transition-colors ${
            activeCategory === cat.slug
              ? 'bg-primary text-white'
              : 'border border-border-default bg-bg-surface text-text-secondary hover:text-text-primary'
          }`}
          >
            {cat.name}
          </a>
        ))}
      </div>
    )}

    <ArticleGrid activeCategory={activeCategory} client:visible />
  </div>
</BaseLayout>
