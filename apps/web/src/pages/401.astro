---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Tidak Terautentikasi" description="Silakan login untuk mengakses halaman ini.">
  <main class="flex min-h-[60vh] flex-col items-center justify-center px-4 text-center">
    <h1 class="text-6xl font-bold text-gray-800">401</h1>
    <p class="mt-4 text-xl text-gray-600">Tidak Terautentikasi</p>
    <p class="mt-2 text-gray-500">
      Silakan login untuk mengakses halaman ini.
    </p>
    <a
      href="/login"
      class="mt-6 rounded-lg bg-blue-600 px-6 py-3 text-white transition hover:bg-blue-700"
    >
      Masuk
    </a>
  </main>
</BaseLayout>
