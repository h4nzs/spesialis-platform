---
import BaseLayout from '../layouts/BaseLayout.astro'
interface CmsPage {
  id: string;
  title: string;
  slug: string;
  content: string | null;
  meta: Record<string, unknown> | null;
}

let pageSlug = 'syarat-ketentuan'
let pageTitle = 'Syarat & Ketentuan'
let pageDescription = 'Syarat dan ketentuan penggunaan platform layanan jasa profesional Ahli Panggilan.'
let pageHtml = ''
const apiUrl = import.meta.env.API_URL ?? import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

let useCms = false

try {
  const res = await fetch(`${apiUrl}/api/v1/cms/pages/${pageSlug}`).catch(() => null)
  if (res?.ok) {
    const json = await res.json()
    const cmsPage: CmsPage | undefined = json.data ?? undefined
    if (cmsPage) {
      pageTitle = cmsPage.title
      pageDescription = (cmsPage.meta as Record<string, string> | null)?.description ?? pageDescription
      pageHtml = cmsPage.content ?? ''
      useCms = true
    }
  }
} catch {
  // fallback to hardcoded content below
}

if (!useCms) {
  pageHtml = `
    <p class="text-body-sm text-text-primary leading-relaxed">Terakhir diperbarui: Juli 2026</p>
    <section>
      <h2 class="text-h5 font-semibold text-text-primary">1. Layanan</h2>
      <p class="mt-2 text-text-primary leading-relaxed">
        Ahli Panggilan adalah platform yang menghubungkan pelanggan dengan penyedia jasa profesional. Kami hanya menyediakan platform — pelaksanaan layanan dilakukan sepenuhnya oleh mitra penyedia jasa.
      </p>
    </section>
    <section>
      <h2 class="text-h5 font-semibold text-text-primary">2. Penggunaan Platform</h2>
      <p class="mt-2 text-text-primary leading-relaxed">
        Dengan menggunakan platform Ahli Panggilan, Anda menyetujui untuk memberikan informasi yang akurat, tidak menyalahgunakan platform, dan mematuhi seluruh ketentuan yang berlaku.
      </p>
    </section>
    <section>
      <h2 class="text-h5 font-semibold text-text-primary">3. Pembayaran</h2>
      <p class="mt-2 text-text-primary leading-relaxed">
        Pembayaran dilakukan sesuai kesepakatan antara pelanggan dan penyedia jasa. Ahli Panggilan tidak memproses pembayaran secara langsung pada fase MVP. Semua transaksi dilakukan secara manual.
      </p>
    </section>
    <section>
      <h2 class="text-h5 font-semibold text-text-primary">4. Pembatalan</h2>
      <p class="mt-2 text-text-primary leading-relaxed">
        Pelanggan dapat membatalkan pesanan sebelum pekerjaan dimulai. Pembatalan dapat dilakukan melalui dashboard atau dengan menghubungi tim Ahli Panggilan.
      </p>
    </section>
    <section>
      <h2 class="text-h5 font-semibold text-text-primary">5. Garansi</h2>
      <p class="mt-2 text-text-primary leading-relaxed">
        Setiap layanan memiliki garansi sesuai dengan ketentuan yang tertera pada halaman layanan. Klaim garansi dapat diajukan melalui fitur komplain di dashboard pelanggan.
      </p>
    </section>
    <section>
      <h2 class="text-h5 font-semibold text-text-primary">6. Privasi</h2>
      <p class="mt-2 text-text-primary leading-relaxed">
        Kami menghormati privasi Anda. Data pribadi Anda dikelola sesuai dengan Kebijakan Privasi yang terpisah. Kami tidak akan membagikan data Anda tanpa persetujuan.
      </p>
    </section>
  `
}
---

<BaseLayout
  title={`${pageTitle} - Ahli Panggilan`}
  description={pageDescription}
  canonicalUrl="/syarat-ketentuan"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: `${pageTitle} - Ahli Panggilan`,
    description: pageDescription,
    breadcrumb: {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Beranda', item: 'https://ahlipanggilan.id' },
        { '@type': 'ListItem', position: 2, name: pageTitle },
      ],
    },
  }}
>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <nav class="mb-8 text-body-sm text-text-secondary">
      <a href="/" class="hover:text-text-primary transition-colors">Beranda</a>
      <span class="mx-2">/</span>
      <span class="text-text-primary">{pageTitle}</span>
    </nav>

    <h1 class="text-h2 font-bold text-text-primary">{pageTitle}</h1>

    <div class="prose mt-8 max-w-none" set:html={pageHtml} />
  </div>
</BaseLayout>
