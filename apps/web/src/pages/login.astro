---
export const prerender = false
import BaseLayout from '../layouts/BaseLayout.astro';
import { LoginForm } from '../components/LoginForm.tsx';
---

<BaseLayout title="Masuk - Spesialis" description="Masuk ke akun Spesialis Anda untuk mengelola booking dan melihat riwayat layanan." noindex={true}>
  <div class="mx-auto flex min-h-[60vh] max-w-md items-center px-4 py-16 sm:px-6">
    <div class="w-full">
      <h1 class="text-center text-h4 font-bold text-text-primary">Masuk</h1>
      <p class="mt-2 text-center text-sm text-text-muted">
        Masuk ke akun Spesialis Anda
      </p>
      <div class="mt-8">
        <LoginForm client:load />
      </div>
    </div>
  </div>
</BaseLayout>
