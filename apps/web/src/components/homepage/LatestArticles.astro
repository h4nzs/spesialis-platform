---
/**
 * Latest Articles Section
 *
 * User problem: "Is this company knowledgeable/credible?"
 * Goal: Show expertise through blog content. Improve SEO via internal linking.
 * Visual: 3 article cards. Mobile: transform-based carousel with arrow nav + dots + swipe.
 *   sm+: Grid 2/3 columns.
 */

interface ArticleItem {
  title: string;
  slug: string;
  summary: string | null;
  coverImage: string | null;
  category: string | null;
  publishedAt: string | null;
}

interface Props {
  articles: ArticleItem[];
}

const { articles } = Astro.props as Props;
const display = articles.slice(0, 3);

function formatDate(iso: string): string {
  try {
    return new Date(iso).toLocaleDateString('id-ID', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    });
  } catch {
    return '';
  }
}
---

<section class="bg-bg-section">
  <div class="container-page py-16 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-overline text-primary-500 tracking-widest">BLOG</p>
      <h2 class="mt-3 text-h2 text-text-primary">Artikel Terbaru</h2>
      <p class="mt-3 text-body-lg text-text-secondary text-pretty">
        Tips, panduan, dan informasi seputar layanan profesional dan perawatan rumah.
      </p>
    </div>

    {
      display.length > 0 ? (
        <div class="relative mt-12" data-article-carousel>
          <div class="overflow-hidden sm:overflow-visible">
            <div
              class="flex sm:grid sm:grid-cols-2 sm:gap-6 md:grid-cols-3 transition-transform duration-300 ease-out sm:!transform-none will-change-transform"
              data-article-track
            >
              {
                display.map((article) => (
                  <div class="w-full flex-shrink-0 sm:w-auto sm:flex-shrink">
                    <a
                      href={`/blog/${article.slug}`}
                      class="group flex h-full flex-col rounded-xl border border-border-default bg-bg-surface overflow-hidden transition-all duration-150 ease-out hover:shadow-sm"
                    >
                      {article.coverImage ? (
                        <div class="aspect-[16/9] overflow-hidden">
                          <img
                            src={article.coverImage}
                            alt={article.title}
                            loading="lazy"
                            decoding="async"
                            width="400"
                            height="225"
                            class="h-full w-full object-cover transition-transform duration-300 ease-out group-hover:scale-105"
                          />
                        </div>
                      ) : (
                        <div class="aspect-[16/9] bg-neutral-100 flex items-center justify-center">
                          <span class="text-h4 text-neutral-300" aria-hidden="true">📝</span>
                        </div>
                      )}

                      <div class="flex flex-col p-5">
                        {article.category && (
                          <span class="self-start rounded-full bg-primary-50 px-3 py-1 text-caption font-medium text-primary-700">
                            {article.category}
                          </span>
                        )}
                        <h3 class="mt-3 text-h5 text-text-primary group-hover:text-primary-600 transition-colors duration-150">
                          {article.title}
                        </h3>
                        {article.summary && (
                          <p class="mt-2 text-body-sm text-text-secondary line-clamp-2 leading-relaxed">
                            {article.summary}
                          </p>
                        )}
                        {article.publishedAt && (
                          <p class="mt-4 text-caption text-text-muted">
                            {formatDate(article.publishedAt)}
                          </p>
                        )}
                      </div>
                    </a>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- ── Arrow buttons (mobile only) ── -->
          {
            display.length > 1 && (
              <>
                <button
                  data-article-prev
                  class="absolute left-1 top-1/2 z-10 h-8 w-8 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-text-primary shadow-sm backdrop-blur-xs transition-all duration-150 ease-out hover:bg-white hover:shadow-md active:scale-95 sm:hidden [@media(pointer:coarse)]:hidden"
                  aria-label="Sebelumnya"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
                </button>
                <button
                  data-article-next
                  class="absolute right-1 top-1/2 z-10 h-8 w-8 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-text-primary shadow-sm backdrop-blur-xs transition-all duration-150 ease-out hover:bg-white hover:shadow-md active:scale-95 sm:hidden [@media(pointer:coarse)]:hidden"
                  aria-label="Berikutnya"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                </button>
              </>
            )
          }

          <!-- ── Dot indicators (mobile only) ── -->
          {
            display.length > 1 && (
              <div class="flex items-center justify-center gap-2 mt-5 sm:hidden" data-article-dots>
                {
                  display.map((_, i) => (
                    <button
                      data-article-dot
                      data-index={i}
                      class="h-2 w-2 rounded-full bg-neutral-300 transition-all duration-300 ease-out cursor-pointer hover:bg-neutral-400 aria-[current=true]:bg-primary-500 aria-[current=true]:w-6"
                      aria-label={`Lihat artikel ${i + 1}`}
                      aria-current={i === 0 ? 'true' : 'false'}
                    />
                  ))
                }
              </div>
            )
          }
        </div>
      ) : null
    }

    <div class="mt-10 text-center">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-body font-medium text-primary-600 hover:text-primary-700 transition-colors duration-150"
      >
        Lihat Semua Artikel
        <span aria-hidden="true" class="text-lg leading-none">&rarr;</span>
      </a>
    </div>
  </div>

  <script>
    (function () {
      const el = document.querySelector('[data-article-carousel]');
      if (!el) return;

      const track = el.querySelector('[data-article-track]') as HTMLElement;
      const prevBtn = el.querySelector('[data-article-prev]') as HTMLElement | null;
      const nextBtn = el.querySelector('[data-article-next]') as HTMLElement | null;
      const dots = el.querySelectorAll('[data-article-dot]') as NodeListOf<HTMLElement>;
      const slides = Array.from(track?.children ?? []) as HTMLElement[];

      if (!track || slides.length === 0) return;

      let current = 0;
      const total = slides.length;

      function goTo(index: number) {
        current = Math.max(0, Math.min(index, total - 1));
        track.style.transform = `translateX(-${current * 100}%)`;

        dots.forEach((dot, i) => {
          const active = i === current;
          dot.setAttribute('aria-current', active ? 'true' : 'false');
          dot.classList.toggle('bg-primary-500', active);
          dot.classList.toggle('w-6', active);
          dot.classList.toggle('bg-neutral-300', !active);
          dot.classList.toggle('w-2', !active);
        });

        if (prevBtn) prevBtn.classList.toggle('hidden', current === 0);
        if (nextBtn) nextBtn.classList.toggle('hidden', current === total - 1);
      }

      prevBtn?.addEventListener('click', () => goTo(current - 1));
      nextBtn?.addEventListener('click', () => goTo(current + 1));

      dots.forEach((dot) => {
        dot.addEventListener('click', () => goTo(Number(dot.dataset.index)));
      });

      // ── Touch swipe ──
      let touchStartX = 0;
      let touchStartY = 0;

      track.addEventListener('touchstart', (e) => {
        const t = (e as TouchEvent).touches[0];
        touchStartX = t.clientX;
        touchStartY = t.clientY;
      }, { passive: true });

      track.addEventListener('touchmove', (e) => {
        const t = (e as TouchEvent).touches[0];
        const dx = t.clientX - touchStartX;
        const dy = t.clientY - touchStartY;
        if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 10) (e as TouchEvent).preventDefault();
      }, { passive: false });

      track.addEventListener('touchend', (e) => {
        const dx = (e as TouchEvent).changedTouches[0].clientX - touchStartX;
        if (Math.abs(dx) > 50) dx < 0 ? goTo(current + 1) : goTo(current - 1);
        touchStartX = 0;
        touchStartY = 0;
      }, { passive: true });

      goTo(0);
    })();
  </script>
</section>
