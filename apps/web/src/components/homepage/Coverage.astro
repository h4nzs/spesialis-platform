---
/**
 * Coverage Section — "Area Layanan"
 *
 * User problem: "Does this service cover my area?"
 * Goal: Answer location question before user reaches FAQ.
 * Visual: Simple list of cities. No map (would need JS).
 */

const areas = [
  { city: 'Jakarta', note: 'Pusat, Selatan, Barat, Timur, Utara' },
  { city: 'Bandung', note: 'Kota dan sekitarnya' },
  { city: 'Tangerang', note: 'Kota dan sekitarnya' },
  { city: 'Bekasi', note: 'Kota dan sekitarnya' },
  { city: 'Depok', note: 'Kota dan sekitarnya' },
  { city: 'Bogor', note: 'Kota dan sekitarnya' },
];
---

<section class="bg-bg-section">
  <div class="container-page py-16 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-overline text-primary-500 tracking-widest">JANGKAUAN</p>
      <h2 class="mt-3 text-h2 text-text-primary">Area Layanan</h2>
      <p class="mt-3 text-body-lg text-text-secondary text-pretty">
        Saat ini kami melayani area Jabodetabek dan Bandung. Kami terus memperluas jangkauan ke kota-kota lain.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        areas.map((area) => (
          <div class="flex items-center gap-4 rounded-lg border border-border-default bg-bg-surface px-5 py-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary-50 text-primary-600" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="text-body font-semibold text-text-primary">{area.city}</p>
              <p class="text-caption text-text-muted">{area.note}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
