---
/**
 * Coverage Section — "Area Layanan"
 *
 * User problem: "Does this service cover my area?"
 * Goal: Answer location question early, build trust that we serve their city.
 * Visual: City pins on a decorative route line + clean city cards grid.
 *
 * Data fetched from API at SSR time — admin can manage via dashboard.
 */

interface CoverageArea {
  id: string;
  city: string;
  note: string | null;
  displayOrder: number;
  isActive: string;
}

const apiUrl = process.env.API_URL ?? process.env.PUBLIC_API_URL ?? 'http://localhost:3000';

let areas: CoverageArea[] = [];
try {
  const res = await fetch(`${apiUrl}/api/v1/public/coverage-areas`);
  if (res.ok) {
    const json = await res.json();
    areas = json.data ?? [];
  }
} catch {
  // silent — fallback to empty state
}

const cityList = areas.length > 0
  ? areas
  : [
      { city: 'Jakarta', note: 'Pusat, Selatan, Barat, Timur, Utara' },
      { city: 'Bandung', note: 'Kota dan sekitarnya' },
      { city: 'Tangerang', note: 'Kota dan sekitarnya' },
      { city: 'Bekasi', note: 'Kota dan sekitarnya' },
      { city: 'Depok', note: 'Kota dan sekitarnya' },
      { city: 'Bogor', note: 'Kota dan sekitarnya' },
    ].map((c) => ({ ...c, id: '' }));
---

<section class="relative overflow-hidden bg-bg-section">
  <!-- Subtle decoration -->
  <div class="pointer-events-none absolute -left-20 -top-40 hidden h-[400px] w-[400px] rounded-full bg-primary-50/40 blur-3xl lg:block" aria-hidden="true" />
  <div class="pointer-events-none absolute -bottom-20 -right-20 hidden h-[300px] w-[300px] rounded-full bg-secondary-50/30 blur-3xl lg:block" aria-hidden="true" />

  <div class="container-page py-16 md:py-24">
    <!-- ── Section Header ─────────────────────────────────────── -->
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-overline text-primary-500 tracking-widest">JANGKAUAN</p>
      <h2 class="mt-3 text-h2 text-text-primary">Area Layanan</h2>
      <p class="mt-3 text-body-lg text-text-secondary text-pretty">
        Kami melayani area Jabodetabek dan Bandung. Terus memperluas jangkauan ke kota-kota lain.
      </p>
    </div>

    <!-- ── Map illustration: route line with city dots ────────── -->
    <div class="relative mx-auto mt-14 max-w-3xl">
      <!-- Decorative route line (hidden on mobile) -->
      <div class="hidden h-1 w-full rounded-full bg-primary-100 sm:block" aria-hidden="true">
        <div class="flex h-1 items-center justify-between px-2">
          {
            cityList.map((_, i) => (
              <div class="relative" style={`transition-delay: ${i * 100}ms`}>
                <!-- Pin dot on the line -->
                <div class="flex h-4 w-4 -translate-y-1.5 items-center justify-center rounded-full bg-primary-500 ring-4 ring-bg-section">
                  <div class="h-1.5 w-1.5 rounded-full bg-white" />
                </div>
                <!-- City label below line -->
                <p class="absolute left-1/2 -translate-x-1/2 mt-3 w-max text-caption font-medium text-text-muted">
                  {cityList[i]!.city}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Mobile view: show as compact chip-style badges -->
      <div class="flex flex-wrap justify-center gap-2 sm:hidden">
        {
          cityList.map((area) => (
            <div class="flex items-center gap-1.5 rounded-full border border-border-default bg-bg-surface px-3.5 py-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-primary-500">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span class="text-body-sm font-medium text-text-primary">{area.city}</span>
            </div>
          ))
        }
      </div>
    </div>

    <!-- ── City detail cards ──────────────────────────────────── -->
    <div class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        cityList.map((area) => (
          <div class="group rounded-xl border border-border-default bg-bg-surface p-5 transition-all duration-150 ease-out hover:border-primary-200 hover:shadow-xs">
            <div class="flex items-center gap-4">
              <!-- Icon -->
              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-primary-50 text-primary-600 transition-colors duration-150 group-hover:bg-primary-100" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <!-- Text -->
              <div class="min-w-0">
                <p class="text-body font-semibold text-text-primary">{area.city}</p>
                {area.note && <p class="mt-0.5 text-caption text-text-muted truncate">{area.note}</p>}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- ── Bottom note ────────────────────────────────────────── -->
    <p class="mt-8 text-center text-body-sm text-text-secondary">
      Belum ada di kota Anda?{' '}
      <a href="/kontak" class="font-medium text-primary-600 hover:text-primary-700 transition-colors duration-150">
        Hubungi kami
      </a>{' '}
      untuk informasi perkembangan area terbaru.
    </p>
  </div>
</section>
