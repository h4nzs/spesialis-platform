---
/**
 * Coverage Section — Referensi Style
 *
 * Visual: Dua card bersebelahan.
 *   Kiri: "Melayani di X Kota" + chip badges untuk setiap kota
 *   Kanan: "Dipercaya oleh..." + brand logos + rating block 4.8/5
 */

interface CoverageArea {
  id: string;
  city: string;
  note: string | null;
  displayOrder: number;
  isActive: string;
}

const apiUrl = process.env.API_URL ?? process.env.PUBLIC_API_URL ?? 'http://localhost:3000';

let areas: CoverageArea[] = [];
try {
  const res = await fetch(`${apiUrl}/api/v1/public/coverage-areas`);
  if (res.ok) {
    const json = await res.json();
    areas = json.data ?? [];
  }
} catch {
  // silent — fallback to empty state
}

const cityList = areas.length > 0
  ? areas.map((a) => a.city)
  : ['Jakarta', 'Bandung', 'Tangerang', 'Bekasi', 'Depok', 'Bogor'];
---

<section class="bg-bg-section">
  <div class="container-page pt-1.5 pb-4 md:pt-2 md:pb-6">
    <div class="grid gap-4 md:grid-cols-5 md:gap-4">
      <!-- ── Left: Cities Card (2 kolom) ─────────────────────────── -->
      <div class="rounded-xl border border-border-default bg-bg-surface p-5 shadow-xs md:col-span-2">
        <p class="mb-3 text-xs font-bold uppercase tracking-wider text-primary-600">
          MELAYANI DI {cityList.length} KOTA
        </p>
        <div class="flex flex-wrap gap-2">
          {
            cityList.map((city) => (
              <div class="inline-flex items-center gap-1.5 rounded-full bg-neutral-100 px-3 py-1.5 text-xs font-semibold text-neutral-700">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-primary-500">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
                </svg>
                {city}
              </div>
            ))
          }
        </div>
      </div>

      <!-- ── Right: Brands + Rating Card (3 kolom) ──────────────── -->
      <div class="flex flex-wrap items-center justify-between gap-4 rounded-xl border border-border-default bg-bg-surface p-5 shadow-xs md:col-span-3">
        <div class="min-w-0 flex-1">
          <p class="mb-2 text-xs font-semibold text-neutral-600">
            Dipercaya oleh ratusan perusahaan &amp; ribuan pelanggan
          </p>
          <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5">
            <span class="text-xs font-extrabold tracking-wider text-neutral-400">PERTAMINA</span>
            <span class="text-xs font-extrabold tracking-wider text-neutral-400">PLN</span>
            <span class="text-xs font-extrabold tracking-wider text-neutral-400">gojek</span>
            <span class="text-xs font-extrabold tracking-wider text-neutral-400">mandiri</span>
            <span class="text-xs font-extrabold tracking-wider text-neutral-400">BCA</span>
          </div>
        </div>

        <!-- Rating block -->
        <div class="flex flex-col items-end gap-0.5 border-l border-border-default pl-4">
          <span class="text-lg font-extrabold text-neutral-800 leading-none">4.8 / 5</span>
          <div class="flex gap-0.5 text-orange-500" aria-label="Rating 4.8 dari 5">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <span class="text-[10px] text-neutral-500">dari 1000+ ulasan</span>
        </div>
      </div>
    </div>
  </div>
</section>
