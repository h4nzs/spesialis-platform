---
/**
 * Why Choose Us Section — Referensi Style
 *
 * Visual: Dua kolom.
 *   Kiri: dark blue gradient card (why-card) dengan title + 4 stats (2x2 grid)
 *   Kanan: feature grid (2x2) — 4 card dengan icon circle + title + description
 */

interface Props {
  totalServices?: number;
  totalPartners?: number;
  totalCities?: number;
}

const { totalServices = 50, totalPartners = 100, totalCities = 5 } = Astro.props as Props;

const stats = [
  { value: '50.000+', label: 'Order Selesai', icon: 'check' },
  { value: `${totalPartners}+`, label: 'Spesialis Aktif', icon: 'users' },
  { value: `${totalCities}`, label: 'Kota Layanan', icon: 'map' },
  { value: '4.8', label: 'Rating Pelanggan', icon: 'star' },
];

const benefits = [
  {
    title: 'Profesional & Terverifikasi',
    description: 'Semua mitra melalui proses seleksi ketat dan terpercaya.',
    icon: 'shield',
    iconBg: 'bg-blue-100 text-blue-600',
  },
  {
    title: 'Cepat & Tepat Waktu',
    description: 'Ahli datang sesuai jadwal yang Anda pilih.',
    icon: 'clock',
    iconBg: 'bg-orange-100 text-orange-600',
  },
  {
    title: 'Harga Jelas & Transparan',
    description: 'Estimasi harga di awal, tanpa biaya tambahan.',
    icon: 'tag',
    iconBg: 'bg-green-100 text-green-600',
  },
  {
    title: 'Garansi Layanan',
    description: 'Kepuasan Anda adalah prioritas kami.',
    icon: 'headphones',
    iconBg: 'bg-purple-100 text-purple-500',
  },
];

const iconSVGs: Record<string, string> = {
  check: '<svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>',
  users: '<svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  map: '<svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>',
  star: '<svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>',
  shield: '<svg xmlns="http://www.w3.org/2000/svg" width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
  clock: '<svg xmlns="http://www.w3.org/2000/svg" width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>',
  tag: '<svg xmlns="http://www.w3.org/2000/svg" width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41 11 3.83A2 2 0 0 0 9.61 3H4a1 1 0 0 0-1 1v5.61a2 2 0 0 0 .83 1.39l9.58 9.58a2 2 0 0 0 2.83 0l4.35-4.35a2 2 0 0 0 0-2.82Z"/><circle cx="7.5" cy="7.5" r="1.3"/></svg>',
  headphones: '<svg xmlns="http://www.w3.org/2000/svg" width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>',
};
---

<section class="bg-bg-section">
  <div class="container-page py-6 md:py-8">
    <div class="grid gap-5 md:grid-cols-5 md:gap-5">
      <!-- ── Left: Dark Blue Card (mengisi 2 kolom) ──────────────── -->
      <div class="flex flex-col justify-between gap-6 rounded-2xl bg-gradient-to-br from-primary-800 to-primary-950 p-6 md:col-span-2 md:p-7">
        <h3 class="text-xl font-extrabold text-white leading-snug">
          Mengapa Memilih<br />Ahli Panggilan?
        </h3>
        <div class="grid grid-cols-2 gap-x-4 gap-y-5">
          {
            stats.map((s) => (
              <div class="flex flex-col gap-1">
                <div class="flex items-center gap-1.5 text-lg font-extrabold text-white leading-none">
                  <span class="shrink-0 text-orange-400" aria-hidden="true" set:html={iconSVGs[s.icon]} />
                  {s.value}
                </div>
                <span class="text-xs font-medium text-blue-200/80 leading-tight">{s.label}</span>
              </div>
            ))
          }
        </div>
      </div>

      <!-- ── Right: Feature Grid (mengisi 3 kolom) ──────────────── -->
      <div class="grid grid-cols-2 gap-3 md:col-span-3">
        {
          benefits.map((b) => (
            <div class="flex flex-col rounded-xl border border-border-default bg-bg-surface p-4 md:p-5 shadow-xs">
              <div class={`mb-3 flex h-10 w-10 items-center justify-center rounded-lg ${b.iconBg}`} aria-hidden="true">
                <span set:html={iconSVGs[b.icon]} />
              </div>
              <h4 class="text-sm font-extrabold text-text-primary leading-snug">{b.title}</h4>
              <p class="mt-1 text-xs text-text-secondary leading-relaxed">{b.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
