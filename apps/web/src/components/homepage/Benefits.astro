---
/**
 * Benefits Section — "Mengapa Spesialis?"
 *
 * User problem: "Why should I trust this platform over alternatives?"
 * Goal: Build trust through specific, credible value propositions.
 * Visual: 2x2 grid on desktop, 1 col on mobile. Icon + title + description.
 *   No floating cards. No excessive shadow. Clean typography.
 */

const benefits = [
  {
    title: 'Teknisi Berpengalaman',
    description: 'Setiap mitra telah melewati proses verifikasi dan memiliki pengalaman di bidangnya.',
    icon: 'users',
  },
  {
    title: 'Harga Transparan',
    description: 'Estimasi harga jelas di awal. Tidak ada biaya tersembunyi atau kejutan.',
    icon: 'badge-check',
  },
  {
    title: 'Cepat & Mudah',
    description: 'Booking dalam hitungan menit. Tanpa perlu antre, tanpa telepon bolak-balik.',
    icon: 'zap',
  },
  {
    title: 'Garansi Layanan',
    description: 'Setiap layanan dilindungi garansi. Jika tidak sesuai, kami siap tindak lanjut.',
    icon: 'shield',
  },
];

// Map icon names to Lucide icon SVGs (inlined for zero JS)
const iconSVGs: Record<string, string> = {
  users: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  'badge-check': '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/></svg>',
  zap: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>',
  shield: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>',
};
---

<section class="bg-bg-page">
  <div class="container-page py-16 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-overline text-primary-500 tracking-widest">KENAPA SPESIALIS</p>
      <h2 class="mt-3 text-h2 text-text-primary">Mengapa Memilih Kami</h2>
      <p class="mt-3 text-body-lg text-text-secondary text-pretty">
        Kami hadir untuk memberikan pengalaman layanan jasa yang berbeda — lebih cepat, lebih transparan, lebih terpercaya.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      {
        benefits.map((b) => (
          <div class="flex gap-5 rounded-xl border border-border-default bg-bg-surface p-6 md:p-8">
            <div class="mt-1 flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-primary-50 text-primary-600" aria-hidden="true">
              <span set:html={iconSVGs[b.icon]} />
            </div>
            <div class="min-w-0">
              <h3 class="text-h5 text-text-primary">{b.title}</h3>
              <p class="mt-2 text-body text-text-secondary leading-relaxed">{b.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
