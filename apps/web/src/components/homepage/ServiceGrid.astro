---
/**
 * Service Grid Section
 *
 * User problem: "What services do they offer?"
 * Goal: Allow quick scanning of available services.
 * Visual: Border-only cards, consistent height, icon-driven.
 *
 * CMS: title → section heading, content → subtitle
 */

export interface ServiceItem {
  id: string;
  name: string;
  slug: string;
  shortDescription: string | null;
  basePrice: number;
  estimatedDuration: number | null;
}

interface Props {
  services: ServiceItem[];
  /** CMS section data — falls back to hardcoded defaults */
  section?: {
    title: string | null;
    content: string | null;
  };
}

const { services, section } = Astro.props as Props;

const sectionTitle = section?.title ?? 'Layanan Profesional'
const sectionContent = section?.content ?? 'Pilih layanan yang Anda butuhkan — harga transparan, teknisi berpengalaman, garansi kepuasan.'

function formatPrice(price: number): string {
  return new Intl.NumberFormat('id-ID', {
    style: 'currency',
    currency: 'IDR',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(price);
}
---

<section class="bg-bg-section" id="layanan">
  <div class="container-page py-16 md:py-24">
    <!-- Section header -->
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-overline text-primary-500 tracking-widest">LAYANAN</p>
      <h2 class="mt-3 text-h2 text-text-primary">{sectionTitle}</h2>
      <p class="mt-3 text-body-lg text-text-secondary text-pretty">{sectionContent}</p>
    </div>

    <!-- Service grid -->
    {
      services.length > 0 ? (
        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {
            services.map((service) => (
              <a
                href={`/services/${service.slug}`}
                class="group flex flex-col rounded-xl border border-border-default bg-bg-surface p-6 transition-all duration-150 ease-out hover:border-primary-200 hover:shadow-sm"
              >
                <h3 class="text-h5 text-text-primary group-hover:text-primary-600 transition-colors duration-150">
                  {service.name}
                </h3>
                {service.shortDescription && (
                  <p class="mt-2 flex-1 text-body-sm text-text-secondary leading-relaxed">
                    {service.shortDescription}
                  </p>
                )}
                <div class="mt-5 flex items-center justify-between border-t border-border-default pt-4">
                  <span class="text-body font-semibold text-primary-500">
                    {formatPrice(service.basePrice)}
                  </span>
                  {service.estimatedDuration && (
                    <span class="text-caption text-text-muted">
                      &plusmn;{service.estimatedDuration} menit
                    </span>
                  )}
                </div>
              </a>
            ))
          }
        </div>
      ) : (
        <div class="mt-12 text-center">
          <p class="text-body text-text-muted">
            Belum ada layanan tersedia saat ini. Silakan kembali lagi nanti.
          </p>
        </div>
      )
    }

    <!-- View all link -->
    <div class="mt-10 text-center">
      <a
        href="/services"
        class="inline-flex items-center gap-2 text-body font-medium text-primary-600 hover:text-primary-700 transition-colors duration-150"
      >
        Lihat Semua Layanan
        <span aria-hidden="true" class="text-lg leading-none">&rarr;</span>
      </a>
    </div>
  </div>
</section>
