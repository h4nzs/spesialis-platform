---
/**
 * Testimonials Section — "Apa Kata Pelanggan"
 *
 * User problem: "Is this service actually good? What do other people say?"
 * Goal: Social proof through authentic-looking testimonials.
 * Visual: Clean quote cards. Mobile: transform-based carousel with arrow nav + dots + swipe.
 *   sm+: Grid 2/3 columns.
 *
 * Content sourced from CMS API (cms_testimonials) for editability via admin dashboard.
 * Falls back to hardcoded defaults if CMS is unreachable.
 */

interface TestimonialItem {
  name: string;
  location: string | null;
  quote: string;
  rating: string;
}

const FALLBACK_TESTIMONIALS: TestimonialItem[] = [
  {
    quote: 'Teknisinya datang tepat waktu, pekerjaan rapi, dan harga sesuai estimasi. Sangat puas dengan layanan AC cleaning-nya.',
    name: 'Rina Wijaya',
    location: 'Jakarta Selatan',
    rating: '5',
  },
  {
    quote: 'Langganan maintenance rutin untuk kantor. Timnya profesional, cepat tanggap, dan selalu komunikatif. Highly recommended!',
    name: 'Bambang Sutrisno',
    location: 'Bandung',
    rating: '5',
  },
  {
    quote: 'Pipa bocor tengah malam, tapi admin respon cepat dan teknisi datang dalam 2 jam. Thank you Ahli Panggilan!',
    name: 'Dewi Lestari',
    location: 'Tangerang',
    rating: '5',
  },
];

const apiUrl = process.env.API_URL ?? process.env.PUBLIC_API_URL ?? 'http://localhost:3000';

let testimonials: TestimonialItem[] = FALLBACK_TESTIMONIALS;
try {
  const res = await fetch(`${apiUrl}/api/v1/cms/testimonials`);
  if (res.ok) {
    const json = await res.json();
    const raw = json.data ?? [];
    if (Array.isArray(raw) && raw.length > 0) {
      testimonials = raw.map((item: { name: string; location: string | null; quote: string; rating: string }) => ({
        name: item.name,
        location: item.location,
        quote: item.quote,
        rating: item.rating,
      }));
    }
  }
} catch {
  // use fallback
}

function starSVG(filled: boolean): string {
  return filled
    ? '<svg class="inline-block h-4 w-4 text-warning-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>'
    : '<svg class="inline-block h-4 w-4 text-neutral-200" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';
}

const chevronLeft = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>';
const chevronRight = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>';
---

<section class="bg-bg-page">
  <div class="container-page py-16 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-overline text-primary-500 tracking-widest">TESTIMONI</p>
      <h2 class="mt-3 text-h2 text-text-primary">Apa Kata Pelanggan</h2>
      <p class="mt-3 text-body-lg text-text-secondary text-pretty">
        Ribuan pelanggan telah menggunakan layanan kami. Ini cerita mereka.
      </p>
    </div>

    <!-- ── Carousel Container ── -->
    <div class="relative mt-12" data-carousel>
      <!-- Overflow wrapper — hidden on mobile only -->
      <div class="overflow-hidden sm:overflow-visible">
        <!-- Track — flex on mobile (translateX via JS), grid on sm+ -->
        <div
          class="flex sm:grid sm:grid-cols-2 sm:gap-6 md:grid-cols-3 transition-transform duration-300 ease-out sm:!transform-none will-change-transform"
          data-track
        >
          {
            testimonials.map((t) => (
              <div class="w-full flex-shrink-0 sm:w-auto sm:flex-shrink">
                <div class="flex h-full flex-col rounded-xl border border-border-default bg-bg-surface p-6 md:p-8">
                  <!-- Star rating -->
                  <div class="flex gap-0.5" role="img" aria-label={`${t.rating} dari 5 bintang`}>
                    {
                      [1, 2, 3, 4, 5].map((star) => (
                        <span set:html={starSVG(star <= Number(t.rating))} />
                      ))
                    }
                  </div>

                  <!-- Quote -->
                  <blockquote class="mt-4 flex-1 text-body text-text-secondary leading-relaxed [overflow-wrap:break-word] [word-break:break-word]">
                    &ldquo;{t.quote}&rdquo;
                  </blockquote>

                  <!-- Author -->
                  <div class="mt-6 border-t border-border-default pt-4">
                    <p class="text-body-sm font-semibold text-text-primary">{t.name}</p>
                    <p class="text-caption text-text-muted">{t.location}</p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- ── Arrow buttons (mobile only) ── -->
      {
        testimonials.length > 1 && (
          <>
            <button
              data-prev
              class="absolute left-1 top-1/2 z-10 h-8 w-8 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-text-primary shadow-sm backdrop-blur-xs transition-all duration-150 ease-out hover:bg-white hover:shadow-md active:scale-95 sm:hidden [@media(pointer:coarse)]:hidden"
              aria-label="Sebelumnya"
            >
              <span set:html={chevronLeft} aria-hidden="true" />
            </button>
            <button
              data-next
              class="absolute right-1 top-1/2 z-10 h-8 w-8 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-text-primary shadow-sm backdrop-blur-xs transition-all duration-150 ease-out hover:bg-white hover:shadow-md active:scale-95 sm:hidden [@media(pointer:coarse)]:hidden"
              aria-label="Berikutnya"
            >
              <span set:html={chevronRight} aria-hidden="true" />
            </button>
          </>
        )
      }

      <!-- ── Dot indicators (mobile only) ── -->
      {
        testimonials.length > 1 && (
          <div class="flex items-center justify-center gap-2 mt-5 sm:hidden" data-dots>
            {
              testimonials.map((_, i) => (
                <button
                  data-dot
                  data-index={i}
                  class="h-2 w-2 rounded-full bg-neutral-300 transition-all duration-300 ease-out cursor-pointer hover:bg-neutral-400 aria-[current=true]:bg-primary-500 aria-[current=true]:w-6"
                  aria-label={`Lihat testimoni ${i + 1}`}
                  aria-current={i === 0 ? 'true' : 'false'}
                />
              ))
            }
          </div>
        )
      }
    </div>

    <script>
      (function () {
        const el = document.querySelector('[data-carousel]');
        if (!el) return;

        const track = el.querySelector('[data-track]') as HTMLElement;
        const prevBtn = el.querySelector('[data-prev]') as HTMLElement | null;
        const nextBtn = el.querySelector('[data-next]') as HTMLElement | null;
        const dots = el.querySelectorAll('[data-dot]') as NodeListOf<HTMLElement>;
        const slides = Array.from(track?.children ?? []) as HTMLElement[];

        if (!track || slides.length === 0) return;

        let current = 0;
        const total = slides.length;

        function goTo(index: number) {
          current = Math.max(0, Math.min(index, total - 1));

          // Slide the track
          track.style.transform = `translateX(-${current * 100}%)`;

          // Update dots via aria-current
          dots.forEach((dot, i) => {
            const active = i === current;
            dot.setAttribute('aria-current', active ? 'true' : 'false');
            dot.classList.toggle('bg-primary-500', active);
            dot.classList.toggle('w-6', active);
            dot.classList.toggle('bg-neutral-300', !active);
            dot.classList.toggle('w-2', !active);
          });

          // Toggle arrow disabled state
          if (prevBtn) prevBtn.classList.toggle('hidden', current === 0);
          if (nextBtn) nextBtn.classList.toggle('hidden', current === total - 1);
        }

        // Arrow click
        prevBtn?.addEventListener('click', () => goTo(current - 1));
        nextBtn?.addEventListener('click', () => goTo(current + 1));

        // Dot click
        dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            goTo(Number(dot.dataset.index));
          });
        });

        // ── Touch swipe ──
        let touchStartX = 0;
        let touchStartY = 0;

        track.addEventListener(
          'touchstart',
          (e) => {
            touchStartX = (e as TouchEvent).touches[0].clientX;
            touchStartY = (e as TouchEvent).touches[0].clientY;
          },
          { passive: true },
        );

        track.addEventListener(
          'touchmove',
          (e) => {
            const dx = (e as TouchEvent).touches[0].clientX - touchStartX;
            const dy = (e as TouchEvent).touches[0].clientY - touchStartY;
            // Only prevent default if swiping horizontally
            if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 10) {
              (e as TouchEvent).preventDefault();
            }
          },
          { passive: false },
        );

        track.addEventListener(
          'touchend',
          (e) => {
            const dx = (e as TouchEvent).changedTouches[0].clientX - touchStartX;
            if (Math.abs(dx) > 50) {
              if (dx < 0) goTo(current + 1);
              else goTo(current - 1);
            }
            touchStartX = 0;
            touchStartY = 0;
          },
          { passive: true },
        );

        // ── Init ──
        goTo(0);
      })();
    </script>
  </div>
</section>
