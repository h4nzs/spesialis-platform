---
/**
 * Featured Services Section
 *
 * User problem: "Which services are most popular/recommended?"
 * Goal: Guide users toward curated services.
 * Visual: Highlighted cards with "Populer" badge.
 * Only rendered when at least one service has isFeatured === true.
 */

export interface FeaturedService {
  id: string;
  name: string;
  slug: string;
  shortDescription: string | null;
  basePrice: number;
  isFeatured: boolean | null;
}

interface Props {
  services: FeaturedService[];
}

const { services } = Astro.props as Props;
const featured = services.filter((s) => s.isFeatured === true);

function formatPrice(price: number): string {
  return new Intl.NumberFormat('id-ID', {
    style: 'currency',
    currency: 'IDR',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(price);
}
---

{
  featured.length > 0 && (
    <section class="bg-bg-page">
      <div class="container-page py-16 md:py-24">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-overline text-primary-500 tracking-widest">POPULER</p>
          <h2 class="mt-3 text-h2 text-text-primary">Layanan Populer</h2>
          <p class="mt-3 text-body-lg text-text-secondary text-pretty">
            Ini dia layanan yang paling banyak dipesan pelanggan kami.
          </p>
        </div>

        <div class="mt-12 grid gap-6 sm:grid-cols-2 md:grid-cols-3">
          {
            featured.slice(0, 3).map((service) => (
              <a
                href={`/services/${service.slug}`}
                class="group relative flex flex-col rounded-xl border-2 border-primary-100 bg-bg-surface p-6 transition-all duration-150 ease-out hover:border-primary-300 hover:shadow-sm"
              >
                <span class="absolute -top-3 right-4 inline-flex items-center rounded-full bg-primary-500 px-3 py-1 text-caption font-semibold text-white shadow-xs">
                  Populer
                </span>
                <h3 class="text-h5 text-text-primary group-hover:text-primary-600 transition-colors duration-150">
                  {service.name}
                </h3>
                {service.shortDescription && (
                  <p class="mt-2 flex-1 text-body-sm text-text-secondary leading-relaxed">
                    {service.shortDescription}
                  </p>
                )}
                <p class="mt-5 text-body font-semibold text-primary-500">
                  {formatPrice(service.basePrice)}
                </p>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  )
}
