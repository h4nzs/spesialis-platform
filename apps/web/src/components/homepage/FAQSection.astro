---
/**
 * FAQ Section
 *
 * User problem: "I have questions about how this works."
 * Goal: Self-serve answers to reduce support burden.
 * Visual: Clean accordion using native <details>/<summary>.
 *   Zero JavaScript required. Respects reduced-motion.
 *
 * Content sourced from CMS API (cms_faq) for editability.
 * Falls back to hardcoded defaults if CMS is unreachable.
 */

interface FaqItem {
  q: string
  a: string
}

const FALLBACK_FAQS: FaqItem[] = [
  {
    q: 'Apa itu Ahli Panggilan?',
    a: 'Ahli Panggilan adalah perusahaan penyedia layanan jasa profesional yang siap membantu kebutuhan rumah, kantor, dan bisnis Anda. Kami memiliki tim teknisi dan profesional berpengalaman di berbagai bidang.',
  },
  {
    q: 'Apakah saya perlu membuat akun untuk booking?',
    a: 'Tidak. Anda dapat melakukan booking tanpa membuat akun sebagai guest. Namun, dengan membuat akun Anda bisa melacak riwayat order, menyimpan alamat, dan mendapatkan kemudahan lainnya.',
  },
  {
    q: 'Bagaimana cara menentukan harga final?',
    a: 'Harga awal adalah estimasi. Harga final akan ditentukan setelah admin melakukan komunikasi melalui WhatsApp untuk menyesuaikan kondisi lapangan, lokasi, dan kebutuhan spesifik.',
  },
  {
    q: 'Bagaimana cara pembayaran?',
    a: 'Pembayaran dilakukan secara manual setelah pekerjaan selesai. Metode yang tersedia: Transfer Bank, Tunai, QRIS, dan E-Wallet.',
  },
  {
    q: 'Bagaimana cara bergabung dengan tim kami?',
    a: 'Daftar melalui halaman Daftar Mitra, lengkapi data diri dan dokumen yang diperlukan. Setelah diverifikasi oleh admin, Anda dapat mulai bergabung.',
  },
  {
    q: 'Apakah ada garansi untuk layanan?',
    a: 'Setiap layanan dilengkapi garansi. Jika ada ketidaksesuaian, Anda dapat mengajukan komplain melalui dashboard dan tim kami akan segera menindaklanjuti.',
  },
];

const apiUrl = process.env.API_URL ?? process.env.PUBLIC_API_URL ?? 'http://localhost:3000'

let faqs: FaqItem[] = FALLBACK_FAQS
try {
  const res = await fetch(`${apiUrl}/api/v1/cms/faq`)
  if (res.ok) {
    const json = await res.json()
    const raw = json.data ?? []
    if (Array.isArray(raw) && raw.length > 0) {
      faqs = raw.map((item: { question: string; answer: string }) => ({
        q: item.question,
        a: item.answer,
      }))
    }
  }
} catch {
  // use fallback
}
---

<section class="bg-bg-page" id="faq-section">
  <div class="container-page py-16 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-overline text-primary-500 tracking-widest">FAQ</p>
      <h2 class="mt-3 text-h2 text-text-primary">Pertanyaan Umum</h2>
      <p class="mt-3 text-body-lg text-text-secondary text-pretty">
        Temukan jawaban untuk pertanyaan yang sering diajukan.
      </p>
    </div>

    <div class="mx-auto mt-12 max-w-2xl space-y-3">
      {
        faqs.map((faq) => (
          <details class="group rounded-xl border border-border-default bg-bg-surface transition-shadow duration-150 ease-out hover:shadow-xs">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-body font-medium text-text-primary select-none">
              {faq.q}
              <span class="ml-4 shrink-0 text-text-muted transition-transform duration-150 ease-out group-open:rotate-180" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </span>
            </summary>
            <div class="border-t border-border-default px-6 py-4 text-body text-text-secondary leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))
      }
    </div>

    <div class="mt-8 text-center">
      <p class="text-body-sm text-text-secondary">
        Masih punya pertanyaan?{' '}
        <a href="/kontak" class="font-medium text-primary-600 hover:text-primary-700 transition-colors duration-150">
          Hubungi kami
        </a>
      </p>
    </div>
  </div>
</section>

<script>
  import { trackFAQOpen } from '../../analytics/astro-track.ts'

  document.addEventListener('DOMContentLoaded', function () {
    var detailsList = document.querySelectorAll('#faq-section details');
    detailsList.forEach(function (details, index) {
      details.addEventListener('toggle', function () {
        if ((details as HTMLDetailsElement).open) {
          var question = details.querySelector('summary')?.textContent?.trim() || '';
          trackFAQOpen('faq-' + index, question, 'homepage');
        }
      });
    });
  });
</script>
