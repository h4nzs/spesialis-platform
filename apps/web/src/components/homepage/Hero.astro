---
/**
 * Hero Section — Compact Landing (Reference Style)
 *
 * Visual: Mirip referensi ahli-panggilan-landing.html.
 *   - Left: eyebrow, headline with blue highlight, description, CTAs, trust row
 *   - Right: floating stat badges over hero background image
 *   - Compact, viewport-filling, no wasted space.
 *
 * CMS: title → headline, content → subtitle
 */

interface Props {
  totalServices?: number;
  totalPartners?: number;
  totalCities?: number;
  /** CMS section data — falls back to hardcoded defaults */
  section?: {
    title: string | null;
    content: string | null;
  };
}

const { totalServices = 50, totalPartners = 100, totalCities = 5, section } = Astro.props as Props;

const headline =
  section?.title ??
  'Layanan Profesional <span class="text-primary-500">Tanpa Ribet</span>';
const subtitle =
  section?.content ??
  'Temukan teknisi dan profesional terpercaya untuk kebutuhan rumah, kantor, dan bisnis Anda. Booking dalam hitungan menit.';
---

<section class="relative overflow-hidden bg-bg-page pt-6 pb-4 md:pt-8 md:pb-6">
  <!-- Full background hero image -->
  <picture>
    <source srcset="/hero-home.webp" type="image/webp" />
    <img
      src="/hero-home.jpg"
      alt=""
      class="absolute inset-0 h-full w-full object-cover object-bottom"
      loading="eager"
      fetchpriority="high"
    />
  </picture>
  <!-- Gradient overlay: solid left → transparent right (image visible on right) -->
  <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-bg-page)] via-[var(--color-bg-page)]/80 to-transparent lg:via-[var(--color-bg-page)]/30" aria-hidden="true" />

  <div class="relative z-10 w-full container-page">
    <div class="grid gap-4 lg:grid-cols-12 lg:gap-6">
      <!-- ── Left Column (7/12) ──────────────────────────────────── -->
      <div class="lg:col-span-7">
        <!-- Eyebrow -->
        <p class="text-caption font-semibold uppercase tracking-[0.2em] text-primary-500">
          LAYANAN PROFESIONAL ON-DEMAND
        </p>

        <!-- Headline -->
        <h1 class="mt-1 text-h1 text-balance text-text-primary leading-[1.1]" set:html={headline} />

        <!-- Subtitle -->
        <p class="mt-1.5 max-w-lg text-body-sm text-text-secondary text-pretty leading-relaxed">
          {subtitle}
        </p>

        <!-- CTA Buttons -->
        <div class="mt-3 flex flex-col gap-2 sm:flex-row">
          <a
            href="/services"
            class="inline-flex h-9 items-center justify-center rounded-lg bg-primary-500 px-4 text-body-sm font-semibold text-white shadow-xs transition-all duration-150 ease-out hover:bg-primary-600 hover:shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1 shrink-0"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Booking Sekarang
          </a>
          <button
            id="btn-lihat-selengkapnya"
            type="button"
            class="inline-flex h-9 cursor-pointer items-center justify-center rounded-lg border border-border-default bg-bg-surface px-4 text-body-sm font-medium text-text-primary shadow-xs transition-all duration-150 ease-out hover:bg-bg-section hover:shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1 shrink-0"><polyline points="6 9 12 15 18 9"/></svg>
            Lihat Selengkapnya
          </button>
        </div>

        <!-- Trust Indicators -->
        <div class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-1.5">
          <div class="flex items-center gap-2.5">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-border-default bg-bg-surface text-primary-600 shadow-xs" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <p class="text-caption font-semibold text-text-primary leading-none">Terverifikasi</p>
              <p class="text-[11px] text-text-muted leading-tight">Profesional Terpercaya</p>
            </div>
          </div>
          <div class="flex items-center gap-2.5">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-border-default bg-bg-surface text-primary-600 shadow-xs" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </div>
            <div>
              <p class="text-caption font-semibold text-text-primary leading-none">24/7 Siap</p>
              <p class="text-[11px] text-text-muted leading-tight">Kapanpun Anda Butuh</p>
            </div>
          </div>
          <div class="flex items-center gap-2.5">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-border-default bg-bg-surface text-primary-600 shadow-xs" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <div>
              <p class="text-caption font-semibold text-text-primary leading-none">Harga Jelas</p>
              <p class="text-[11px] text-text-muted leading-tight">Tanpa Biaya Tersembunyi</p>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Right Column (5/12) — Floating Badges compact (desktop only) ── -->
      <div class="hidden lg:flex lg:col-span-5 lg:flex-col lg:items-end lg:gap-3 lg:self-start lg:pt-2">
        <!-- Badge 1 -->
        <div class="flex items-center gap-2.5 rounded-xl border border-border-default bg-white/95 px-3.5 py-2.5 shadow-md backdrop-blur-sm">
          <div class="flex h-9 w-9 items-center justify-center rounded-full bg-primary-500 text-white shadow-sm" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div>
            <p class="text-base font-extrabold text-text-primary leading-none">{totalPartners}+</p>
            <p class="text-[11px] text-text-muted leading-tight">Spesialis Profesional<br />Siap Membantu</p>
          </div>
        </div>

        <!-- Badge 2 -->
        <div class="flex items-center gap-2.5 rounded-xl border border-border-default bg-white/95 px-3.5 py-2.5 shadow-md backdrop-blur-sm">
          <div class="flex h-9 w-9 items-center justify-center rounded-full bg-warning-50 text-warning-600 shadow-sm" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <div>
            <p class="text-base font-extrabold text-text-primary leading-none">{totalServices}+ Layanan</p>
            <p class="text-[11px] text-text-muted leading-tight">Rating 4.8 / 5 dari 1.000+ ulasan</p>
          </div>
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-warning-100 text-warning-700 border-2 border-warning-500 text-[9px] font-extrabold leading-tight shadow-xs flex-col">
            24<span class="text-[6px] font-bold">JAM</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var btn = document.getElementById('btn-lihat-selengkapnya');
    var content = document.getElementById('homepage-content');
    if (btn && content) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        content.classList.remove('hidden');
        content.classList.add('animate-fade-in-up');
        // Reveal footer
        var fa = document.getElementById('global-footer-area');
        if (fa) fa.style.display = '';
        setTimeout(function () {
          content.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 100);
        btn.innerHTML =
          '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1.5 shrink-0"><polyline points="6 9 12 15 18 9"/></svg> Menjelajahi...';
        btn.disabled = true;
        btn.classList.add('opacity-60', 'cursor-not-allowed');
      });
    }
  });
</script>
