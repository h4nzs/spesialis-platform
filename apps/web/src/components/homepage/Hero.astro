---
/**
 * Hero Section — Compact Landing (Reference Style)
 *
 * Visual: Mirip referensi ahli-panggilan-landing.html.
 *   - Left: eyebrow, headline with blue highlight, description, CTAs, trust row
 *   - Right: floating stat badges over hero background image
 *   - Compact, viewport-filling, no wasted space.
 *
 * CMS: title → headline, content → subtitle
 */

interface Props {
  totalServices?: number;
  totalPartners?: number;
  totalCities?: number;
  /** CMS section data — falls back to hardcoded defaults */
  section?: {
    title: string | null;
    content: string | null;
  };
}

const { totalServices = 50, totalPartners = 100, totalCities: _totalCities = 5, section } = Astro.props as Props;

const headline =
  section?.title ??
  'Panggil Ahlinya, <span class="text-primary-500">Semua Beres</span>';
const subtitle =
  section?.content ??
  'Butuh teknisi, montir, tukang, ahli pipa, cleaning service, hingga berbagai tenaga profesional lainnya? Tim Ahli Panggilan siap datang ke lokasi Anda dengan layanan cepat, profesional, dan terpercaya.';
---

<section class="relative overflow-hidden bg-bg-page min-h-[280px] md:min-h-[320px] lg:min-h-[380px] flex flex-col justify-center pt-5 pb-3 md:pt-6 md:pb-3 lg:pt-8 lg:pb-4">
  <!-- Full background hero image
       ⚠️  Hero area: ~280–380px tergantung viewport.
       Pastikan gambar hero-home.webp/jpg beresolusi >= 1920×1080px
       agar tidak terlihat pecah/blur pada area yang lebih luas.
  -->
  <picture>
    <source
      srcset="/hero-home-640.webp 640w, /hero-home-1024.webp 1024w, /hero-home-1536.webp 1536w"
      sizes="100vw"
      type="image/webp"
    />
    <img
      src="/hero-home.webp"
      alt=""
      class="absolute inset-0 h-full w-full object-cover object-bottom"
      loading="eager"
    />
  </picture>
  <!-- Gradient overlay: solid left to transparent right (image visible on right) -->
  <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-bg-page)] via-[var(--color-bg-page)]/80 to-transparent lg:via-[var(--color-bg-page)]/30" aria-hidden="true" />

  <div class="relative z-10 w-full container-page">
    <div class="grid gap-4 lg:grid-cols-12 lg:gap-6">
      <!-- Left Column (7/12) -->
      <div class="lg:col-span-7">
        <!-- Eyebrow -->
        <p class="text-body-sm font-semibold uppercase tracking-[0.25em] md:tracking-[0.3em] text-primary-500">
          LAYANAN PROFESIONAL ON-DEMAND
        </p>

        <!-- Headline -->
        <h1 class="mt-1.5 md:mt-2 text-h1 lg:text-display text-balance text-text-primary leading-[1.15]" set:html={headline} />

        <!-- Subtitle -->
        <p class="mt-1.5 md:mt-2 max-w-xl md:max-w-2xl text-body-sm md:text-body text-text-secondary text-pretty leading-relaxed md:leading-loose">
          {subtitle}
        </p>

        <!-- CTA Buttons -->
        <div class="mt-2.5 md:mt-3 flex flex-col gap-2 sm:flex-row">
          <a
            href="/services"
            id="btn-booking-sekarang"
            class="inline-flex h-9 items-center justify-center rounded-lg bg-warning-700 px-4 text-body-sm font-bold text-white shadow-xs transition-all duration-150 ease-out hover:bg-warning-800 hover:shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-warning-700"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1 shrink-0"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Booking Sekarang
          </a>
          <button
            id="btn-lihat-selengkapnya"
            type="button"
            class="inline-flex h-9 cursor-pointer items-center justify-center rounded-lg border border-border-default bg-bg-surface px-4 text-body-sm font-medium text-text-primary shadow-xs transition-all duration-150 ease-out hover:bg-bg-section hover:shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1 shrink-0"><polyline points="6 9 12 15 18 9"/></svg>
            Lihat Selengkapnya
          </button>
        </div>

        <!-- Trust Indicators -->
        <div class="mt-2 md:mt-2.5 flex flex-wrap items-center gap-x-4 gap-y-1">
          <div class="flex items-center gap-2">
            <div class="flex h-8 w-8 items-center justify-center rounded-full border border-border-default text-primary-500" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <p class="text-caption font-semibold text-text-primary leading-none">Terverifikasi</p>
              <p class="text-[10px] text-text-muted leading-tight">Profesional Terpercaya</p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <div class="flex h-8 w-8 items-center justify-center rounded-full border border-border-default text-primary-500" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </div>
            <div>
              <p class="text-caption font-semibold text-text-primary leading-none">24/7 Siap</p>
              <p class="text-[10px] text-text-muted leading-tight">Kapanpun Anda Butuh</p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <div class="flex h-8 w-8 items-center justify-center rounded-full border border-border-default text-primary-500" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12" rx="2"/><text x="12" y="17" font-family="system-ui,-apple-system,sans-serif" font-weight="800" font-size="11" fill="currentColor" stroke="none" text-anchor="middle">Rp</text></svg>
            </div>
            <div>
              <p class="text-caption font-semibold text-text-primary leading-none">Harga Jelas</p>
              <p class="text-[10px] text-text-muted leading-tight">Tanpa Biaya Tersembunyi</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column (5/12) — Floating Badges compact (desktop only) -->
      <div class="hidden lg:flex lg:col-span-5 lg:flex-col lg:items-end lg:gap-3 lg:self-start lg:pt-2">
        <!-- Card 1 — Statistik (biru solid) -->
        <div class="flex items-center gap-4 rounded-xl bg-primary-600 px-5 py-4 shadow-lg">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0" aria-hidden="true">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
          <div>
            <p class="text-2xl font-extrabold text-white leading-none">{totalPartners}+</p>
            <p class="mt-1 text-xs text-white/80 leading-tight">Spesialis Profesional<br />Siap Membantu</p>
          </div>
        </div>

        <!-- Card 2 — Layanan (putih, vertikal, overlapping 24JAM badge) -->
        <div class="relative -ml-6 rounded-xl bg-white px-5 py-4 pr-10 shadow-lg">
          <p class="text-base font-bold text-warning-600">Layanan 24 Jam</p>
          <ul class="mt-2 space-y-1.5">
            <li class="flex items-center gap-2 text-xs font-medium text-text-primary">
              <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-warning-500" aria-hidden="true" />
              {totalServices}+ Layanan Tersedia
            </li>
            <li class="flex items-center gap-2 text-xs font-medium text-text-primary">
              <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-warning-500" aria-hidden="true" />
              Rating 4.8 / 5 dari 1.000+ ulasan
            </li>
            <li class="flex items-center gap-2 text-xs font-medium text-text-primary">
              <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-warning-500" aria-hidden="true" />
              Siap 24 Jam Nonstop
            </li>
          </ul>
          <!-- 24 JAM badge — overlap di tepi kanan -->
          <div class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/2 flex h-14 w-14 items-center justify-center rounded-full bg-white shadow-md border-2 border-warning-500 flex-col">
            <span class="text-base font-extrabold text-warning-600 leading-none">24</span>
            <span class="text-[7px] font-bold text-warning-600 leading-tight">JAM</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { trackCTA } from '../../analytics/astro-track.ts'

  document.addEventListener('DOMContentLoaded', function () {
    var bookingBtn = document.getElementById('btn-booking-sekarang');
    if (bookingBtn) {
      bookingBtn.addEventListener('click', function () {
        trackCTA('hero', 'Booking Sekarang', 1, '/');
      });
    }

    var lihatBtn = document.getElementById('btn-lihat-selengkapnya');
    var content = document.getElementById('homepage-content');
    if (lihatBtn && content) {
      var btn = lihatBtn as HTMLButtonElement;
      var el = content as HTMLElement;
      btn.addEventListener('click', function (e) {
        trackCTA('hero', 'Lihat Selengkapnya', 2, '/');

        e.preventDefault();
        el.classList.remove('hidden');
        el.classList.add('animate-fade-in-up');
        var fa = document.getElementById('global-footer-area');
        if (fa) (fa as HTMLElement).style.display = '';
        setTimeout(function () {
          el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 100);
        btn.innerHTML =
          '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1.5 shrink-0"><polyline points="6 9 12 15 18 9"/></svg> Menjelajahi...';
        btn.disabled = true;
        btn.classList.add('opacity-60', 'cursor-not-allowed');
      });
    }
  });
</script>
