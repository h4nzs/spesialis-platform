---
/**
 * Footer
 *
 * User problem: "Where can I find more information / legal pages / social media?"
 * Goal: Provide navigation to key pages + trust signals.
 * Visual: 4 columns desktop, 2 columns tablet, 1 column mobile.
 *   Dark background as specified in docs.
 */

const year = new Date().getFullYear();
---

<footer class="border-t border-primary-800 bg-primary-950">
  <div class="container-page py-12 md:py-16">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Column 1: Company info -->
      <div>
        <a href="/" class="block">
          <img src="/logo-dan-text-menyamping-white.png" alt="Ahli Panggilan" width="180" height="33" class="h-9 w-auto" loading="lazy" />
        </a>
        <p class="mt-3 text-body-sm text-primary-200 leading-relaxed max-w-xs">
          Platform layanan jasa profesional on-demand. Menghubungkan pelanggan dengan teknisi terpercaya di Indonesia.
        </p>
      </div>

      <!-- Column 2: Layanan -->
      <div>
        <p class="text-caption font-semibold tracking-wider text-primary-300 uppercase">Layanan</p>
        <ul class="mt-4 space-y-3">
          <li><a href="/services" class="text-body-sm text-primary-200 hover:text-white transition-colors duration-150">Semua Layanan</a></li>
          <li><a href="/tracking" class="text-body-sm text-primary-200 hover:text-white transition-colors duration-150">Lacak Booking</a></li>
          <li><a href="/book" class="text-body-sm text-primary-200 hover:text-white transition-colors duration-150">Booking</a></li>
          <li><a href="/faq" class="text-body-sm text-primary-200 hover:text-white transition-colors duration-150">FAQ</a></li>
        </ul>
      </div>

      <!-- Column 3: Perusahaan -->
      <div>
        <p class="text-caption font-semibold tracking-wider text-primary-300 uppercase">Perusahaan</p>
        <ul class="mt-4 space-y-3">
          <li><a href="/tentang-kami" class="text-body-sm text-primary-200 hover:text-white transition-colors duration-150">Tentang Kami</a></li>
          <li><a href="/blog" class="text-body-sm text-primary-200 hover:text-white transition-colors duration-150">Blog</a></li>
          <li><a href="/kontak" class="text-body-sm text-primary-200 hover:text-white transition-colors duration-150">Kontak</a></li>
          <li><a href="/register/partner" class="text-body-sm text-primary-200 hover:text-white transition-colors duration-150">Daftar Mitra</a></li>
          <li><a href="/corporate" class="text-body-sm text-primary-200 hover:text-white transition-colors duration-150">Korporat</a></li>
        </ul>
      </div>

      <!-- Column 4: Legal & Social -->
      <div>
        <p class="text-caption font-semibold tracking-wider text-primary-300 uppercase">Legal</p>
        <ul class="mt-4 space-y-3">
          <li><a href="/syarat-ketentuan" class="text-body-sm text-primary-200 hover:text-white transition-colors duration-150">Syarat & Ketentuan</a></li>
          <li><a href="/kebijakan-privasi" class="text-body-sm text-primary-200 hover:text-white transition-colors duration-150">Kebijakan Privasi</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 border-t border-primary-800 pt-8">
      <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
        <p class="text-caption text-primary-300">&copy; {year} Ahli Panggilan. All rights reserved.</p>
        <div class="flex gap-4">
          <a href="https://instagram.com/ahlipanggilan.id" target="_blank" rel="noopener noreferrer" class="text-primary-300 hover:text-white transition-colors duration-150" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
            </svg>
          </a>
          <a href="https://facebook.com/ahlipanggilan.id" target="_blank" rel="noopener noreferrer" class="text-primary-300 hover:text-white transition-colors duration-150" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
