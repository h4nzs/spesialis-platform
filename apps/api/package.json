{
  "name": "@ahlipanggilan/api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "start": "tsx --env-file=../../.env src/index.ts",
    "start:prod": "tsx src/index.ts",
    "db:seed": "tsx --env-file=../../.env src/seeds/index.ts",
    "db:seed-data": "tsx --env-file=../../.env src/seeds/seed-data.ts",
    "db:seed-data:prod": "tsx src/seeds/seed-data.ts",
    "db:seed-admin": "tsx --env-file=../../.env src/seeds/seed-admin.ts",
    "db:seed-admin:prod": "tsx src/seeds/seed-admin.ts",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@ahlipanggilan/database": "workspace:*",
    "@ahlipanggilan/shared": "workspace:*",
    "@ahlipanggilan/types": "workspace:*",
    "@ahlipanggilan/validation": "workspace:*",
    "@aws-sdk/client-s3": "^3.1087.0",
    "@hono/node-server": "^2.0.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.43.1",
    "hash-wasm": "^4.12.0",
    "hono": "^4.12.27",
    "ioredis": "^5.11.1",
    "nodemailer": "^7.0.2",
    "resend": "^6.17.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.4",
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^7.0.5",
    "@types/supertest": "^7.2.0",
    "postgres": "^3.4.9",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
